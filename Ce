#!/usr/bin/env bash
set -euo pipefail

# Usage examples:
#   chmod +x check_cert_chain.sh
#   ./check_cert_chain.sh manage.office.com login.microsoftonline.com
#   ./check_cert_chain.sh manage.office.com:443 graph.microsoft.com outlook.office365.com
#
# Or set defaults here and run with no arguments:
DEFAULT_TARGETS=(
  # "manage.office.com"
  # "login.microsoftonline.com"
)

TARGETS=("$@")
if [[ ${#TARGETS[@]} -eq 0 ]]; then
  TARGETS=("${DEFAULT_TARGETS[@]}")
fi

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  echo "Provide one or more targets as arguments, or populate DEFAULT_TARGETS in the script."
  exit 1
fi

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

for cmd in openssl awk sed grep tr; do
  if ! have_cmd "$cmd"; then
    echo "Missing required command: $cmd"
    exit 1
  fi
done

trim() {
  sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

normalize_keyid() {
  tr '[:lower:]' '[:upper:]' | grep -Eo '([0-9A-F]{2}:){3,}[0-9A-F]{2}' | head -n1 | tr -d ':'
}

extract_block_after_label() {
  local label="$1"
  awk -v label="$label" '
    index($0, label) {capture=1; next}
    capture && /^[[:space:]]+/ {print; next}
    capture {exit}
  '
}

parse_target() {
  local target="$1"
  local host port
  if [[ "$target" == *:* ]]; then
    host="${target%%:*}"
    port="${target##*:}"
  else
    host="$target"
    port="443"
  fi
  printf '%s %s\n' "$host" "$port"
}

inspect_target() {
  local target="$1"
  local host port raw chain_count i
  read -r host port < <(parse_target "$target")

  echo
  echo "######################################################################"
  echo "Target: $host:$port"
  echo "######################################################################"

  raw="$(
    openssl s_client \
      -connect "${host}:${port}" \
      -servername "${host}" \
      -showcerts \
      -verify_return_error \
      </dev/null 2>&1 || true
  )"

  if ! grep -q 'BEGIN CERTIFICATE' <<<"$raw"; then
    echo "No certificates were returned."
    echo
    echo "Raw OpenSSL output:"
    echo "$raw"
    return
  fi

  mapfile -d $'\x1e' -t certs < <(
    printf '%s\n' "$raw" | awk '
      /-----BEGIN CERTIFICATE-----/ {in_cert=1; cert=$0 ORS; next}
      in_cert {cert=cert $0 ORS}
      /-----END CERTIFICATE-----/ {printf "%s\x1e", cert; cert=""; in_cert=0}
    '
  )

  chain_count="${#certs[@]}"
  echo "Certificates presented in live chain: $chain_count"
  echo

  if grep -q 'Verify return code:' <<<"$raw"; then
    echo "OpenSSL verify summary:"
    grep 'Verify return code:' <<<"$raw" | tail -n1
    echo
  fi

  declare -a SUBJECTS ISSUERS SKIS AKIS CAFLAGS KEYUSAGES SERIALS

  for ((i=0; i<chain_count; i++)); do
    cert="${certs[$i]}"

    SUBJECTS[$i]="$(openssl x509 -noout -subject -nameopt RFC2253 <<<"$cert" 2>/dev/null | sed 's/^subject=//' | trim)"
    ISSUERS[$i]="$(openssl x509 -noout -issuer  -nameopt RFC2253 <<<"$cert" 2>/dev/null | sed 's/^issuer=//'  | trim)"
    SERIALS[$i]="$(openssl x509 -noout -serial <<<"$cert" 2>/dev/null | sed 's/^serial=//' | trim)"

    text="$(openssl x509 -noout -text <<<"$cert" 2>/dev/null)"

    SKIS[$i]="$(extract_block_after_label 'X509v3 Subject Key Identifier:' <<<"$text" | normalize_keyid || true)"
    AKIS[$i]="$(extract_block_after_label 'X509v3 Authority Key Identifier:' <<<"$text" | normalize_keyid || true)"
    CAFLAGS[$i]="$(extract_block_after_label 'X509v3 Basic Constraints:' <<<"$text" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | trim)"
    KEYUSAGES[$i]="$(extract_block_after_label 'X509v3 Key Usage:' <<<"$text" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | trim)"

    role="intermediate/root"
    if (( i == 0 )); then
      role="leaf/server"
    fi

    echo "===== Certificate $((i+1)) of $chain_count ($role) ====="
    echo "Subject       : ${SUBJECTS[$i]:-(missing)}"
    echo "Issuer        : ${ISSUERS[$i]:-(missing)}"
    echo "Serial        : ${SERIALS[$i]:-(missing)}"
    echo "SKI           : ${SKIS[$i]:-(missing)}"
    echo "AKI           : ${AKIS[$i]:-(missing)}"
    echo "BasicConstraints: ${CAFLAGS[$i]:-(missing)}"
    echo "KeyUsage      : ${KEYUSAGES[$i]:-(missing)}"
    echo
  done

  echo "----- Chain consistency checks -----"

  for ((i=0; i<chain_count; i++)); do
    cert_num=$((i+1))

    if [[ -z "${AKIS[$i]}" ]]; then
      echo "Cert $cert_num: AKI missing"
    fi

    if [[ -z "${SKIS[$i]}" ]]; then
      echo "Cert $cert_num: SKI missing"
    fi

    if (( i == 0 )); then
      if [[ "${CAFLAGS[$i]}" == *"CA:TRUE"* ]]; then
        echo "Cert $cert_num (leaf): unexpected CA:TRUE"
      fi
    else
      if [[ "${CAFLAGS[$i]}" != *"CA:TRUE"* ]]; then
        echo "Cert $cert_num (issuer/intermediate/root): missing or unexpected CA:TRUE"
      fi
      if [[ "${KEYUSAGES[$i]}" != *"Certificate Sign"* && "${KEYUSAGES[$i]}" != *"Certificate Signing"* ]]; then
        echo "Cert $cert_num (issuer/intermediate/root): Key Usage does not clearly show certificate signing"
      fi
    fi

    if (( i + 1 < chain_count )); then
      next=$((i+1))
      next_num=$((next+1))

      if [[ "${ISSUERS[$i]}" == "${SUBJECTS[$next]}" ]]; then
        echo "Cert $cert_num -> Cert $next_num: issuer/subject match = OK"
      else
        echo "Cert $cert_num -> Cert $next_num: issuer/subject match = MISMATCH"
      fi

      if [[ -n "${AKIS[$i]}" && -n "${SKIS[$next]}" ]]; then
        if [[ "${AKIS[$i]}" == "${SKIS[$next]}" ]]; then
          echo "Cert $cert_num -> Cert $next_num: AKI/SKI match = OK"
        else
          echo "Cert $cert_num -> Cert $next_num: AKI/SKI match = MISMATCH"
        fi
      else
        echo "Cert $cert_num -> Cert $next_num: AKI/SKI match = cannot fully evaluate (missing AKI or SKI)"
      fi
    fi
  done

  echo
  echo "----- Raw verification-related lines from s_client -----"
  grep -Ei 'verify error|verify return code|depth=|self-signed|unable to get|certificate' <<<"$raw" || true
  echo
}

for target in "${TARGETS[@]}"; do
  inspect_target "$target"
done
