<form version="1.1">
  <label>CIM Compliance by Data Model / Dataset / Sourcetype</label>

  <init>
    <set token="tok_selected_st">*</set>
  </init>

  <fieldset submitButton="false">
    <input type="time" token="tok_time">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>

    <input type="dropdown" token="tok_dm" searchWhenChanged="true">
      <label>Data Model</label>
      <search>
        <query><![CDATA[
| datamodelsimple type=models
| eval data_model=coalesce(modelName, datamodel, model, title, name)
| where isnotnull(data_model) AND data_model!=""
| dedup data_model
| sort data_model
| table data_model
        ]]></query>
      </search>
      <fieldForLabel>data_model</fieldForLabel>
      <fieldForValue>data_model</fieldForValue>
    </input>

    <input type="dropdown" token="tok_dataset" searchWhenChanged="true">
      <label>Dataset</label>
      <search>
        <query><![CDATA[
| datamodelsimple type=objects datamodel="$tok_dm$"
| eval nodename=coalesce(objectName, nodename, object, name, title)
| eval dataset=mvindex(split(nodename,"."),-1)
| where isnotnull(nodename) AND nodename!=""
| dedup nodename
| sort dataset
| table dataset nodename
        ]]></query>
      </search>
      <fieldForLabel>dataset</fieldForLabel>
      <fieldForValue>dataset</fieldForValue>
      <change>
        <eval token="tok_nodename">$result.nodename$</eval>
        <set token="tok_selected_st">*</set>
      </change>
    </input>

    <input type="text" token="tok_st_filter" searchWhenChanged="true">
      <label>Sourcetype Filter</label>
      <default>*</default>
    </input>

    <input type="radio" token="tok_summariesonly" searchWhenChanged="true">
      <label>Acceleration Mode</label>
      <choice value="false">All data</choice>
      <choice value="true">Summaries only</choice>
      <default>false</default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>Events in Selected Dataset</title>
      <single>
        <search>
          <query><![CDATA[
| datamodel "$tok_dm$" "$tok_dataset$" flat strict_fields=false summariesonly=$tok_summariesonly$
| eval st_filter="$tok_st_filter$"
| where st_filter="*" OR like(sourcetype, replace(st_filter,"*","%"))
| stats count as event_count
          ]]></query>
          <earliest>$tok_time.earliest$</earliest>
          <latest>$tok_time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <title>Sourcetypes in Selected Dataset</title>
      <single>
        <search>
          <query><![CDATA[
| datamodel "$tok_dm$" "$tok_dataset$" flat strict_fields=false summariesonly=$tok_summariesonly$
| eval st_filter="$tok_st_filter$"
| where st_filter="*" OR like(sourcetype, replace(st_filter,"*","%"))
| stats dc(sourcetype) as sourcetype_count
          ]]></query>
          <earliest>$tok_time.earliest$</earliest>
          <latest>$tok_time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <title>Average Compliance Across Sourcetypes</title>
      <single>
        <search>
          <query><![CDATA[
| datamodelsimple type=attributes datamodel="$tok_dm$" nodename="$tok_nodename$"
| eval field_name=coalesce(attributeName, attribute, field, name, title)
| where isnotnull(field_name) AND field_name!="" AND field_name!="_time"
| dedup field_name
| map maxsearches=500 search="
    | datamodel \"$tok_dm$\" \"$tok_dataset$\" flat strict_fields=false summariesonly=$tok_summariesonly$
    | eval st_filter=\"$tok_st_filter$\"
    | where st_filter=\"*\" OR like(sourcetype, replace(st_filter,\"*\",\"%\"))
    | stats count as total count(eval(isnotnull($field_name$) AND tostring($field_name$)!=\"\")) as populated by sourcetype
    | where total>0
    | eval field_name=\"$field_name$\", population_pct=round((populated/total)*100,2)
    | table sourcetype field_name population_pct
  "
| stats avg(population_pct) as compliance_score by sourcetype
| stats avg(compliance_score) as overall_compliance
| eval overall_compliance=round(overall_compliance,2)
          ]]></query>
          <earliest>$tok_time.earliest$</earliest>
          <latest>$tok_time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <title>Dataset Search String</title>
      <table>
        <search>
          <query><![CDATA[
| datamodel "$tok_dm$" "$tok_dataset$" search_string
          ]]></query>
        </search>
        <option name="count">5</option>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Coverage by Sourcetype</title>
      <table>
        <search>
          <query><![CDATA[
| datamodelsimple type=attributes datamodel="$tok_dm$" nodename="$tok_nodename$"
| eval field_name=coalesce(attributeName, attribute, field, name, title)
| where isnotnull(field_name) AND field_name!="" AND field_name!="_time"
| dedup field_name
| map maxsearches=500 search="
    | datamodel \"$tok_dm$\" \"$tok_dataset$\" flat strict_fields=false summariesonly=$tok_summariesonly$
    | eval st_filter=\"$tok_st_filter$\"
    | where st_filter=\"*\" OR like(sourcetype, replace(st_filter,\"*\",\"%\"))
    | stats count as total count(eval(isnotnull($field_name$) AND tostring($field_name$)!=\"\")) as populated by sourcetype
    | where total>0
    | eval field_name=\"$field_name$\", population_pct=round((populated/total)*100,2)
    | table sourcetype field_name total populated population_pct
  "
| stats avg(population_pct) as compliance_score
        min(population_pct) as lowest_field_pct
        dc(field_name) as fields_checked
        max(total) as events
  by sourcetype
| eval compliance_score=round(compliance_score,2)
| eval lowest_field_pct=round(lowest_field_pct,2)
| eval status=case(compliance_score>=90,"Good", compliance_score>=70,"Warning", true(),"Poor")
| sort - compliance_score - events
          ]]></query>
          <earliest>$tok_time.earliest$</earliest>
          <latest>$tok_time.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">row</option>
        <option name="wrap">true</option>

        <format type="color" field="status">
          <colorPalette type="map">{"Good":#65A637,"Warning":#F7BC38,"Poor":#D93F3C}</colorPalette>
        </format>

        <format type="color" field="compliance_score">
          <scale type="threshold">70,90</scale>
          <colorPalette type="list">[#D93F3C,#F7BC38,#65A637]</colorPalette>
        </format>

        <format type="color" field="lowest_field_pct">
          <scale type="threshold">50,80</scale>
          <colorPalette type="list">[#D93F3C,#F7BC38,#65A637]</colorPalette>
        </format>

        <format type="color" field="sourcetype">
          <scale type="sharedCategory"></scale>
          <colorPalette type="sharedList"></colorPalette>
        </format>

        <format type="number" field="compliance_score">
          <option name="precision">2</option>
        </format>

        <format type="number" field="lowest_field_pct">
          <option name="precision">2</option>
        </format>

        <drilldown>
          <set token="tok_selected_st">$row.sourcetype$</set>
        </drilldown>
      </table>
    </panel>

    <panel>
      <title>Field Population for Selected Sourcetype ($tok_selected_st$)</title>
      <table>
        <search>
          <query><![CDATA[
| datamodelsimple type=attributes datamodel="$tok_dm$" nodename="$tok_nodename$"
| eval field_name=coalesce(attributeName, attribute, field, name, title)
| where isnotnull(field_name) AND field_name!="" AND field_name!="_time"
| dedup field_name
| map maxsearches=500 search="
    | datamodel \"$tok_dm$\" \"$tok_dataset$\" flat strict_fields=false summariesonly=$tok_summariesonly$
    | eval selected_st=\"$tok_selected_st$\", st_filter=\"$tok_st_filter$\"
    | where (selected_st!=\"*\" AND sourcetype=selected_st) OR (selected_st=\"*\" AND (st_filter=\"*\" OR like(sourcetype, replace(st_filter,\"*\",\"%\"))))
    | stats count as total count(eval(isnotnull($field_name$) AND tostring($field_name$)!=\"\")) as populated by sourcetype
    | where total>0
    | eval field_name=\"$field_name$\", population_pct=round((populated/total)*100,2)
    | table sourcetype field_name total populated population_pct
  "
| sort population_pct field_name
          ]]></query>
          <earliest>$tok_time.earliest$</earliest>
          <latest>$tok_time.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>

        <format type="color" field="population_pct">
          <scale type="threshold">50,80,95</scale>
          <colorPalette type="list">[#D93F3C,#F7BC38,#6DB7C6,#65A637]</colorPalette>
        </format>

        <format type="number" field="population_pct">
          <option name="precision">2</option>
        </format>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Selected Sourcetype Across All Data Models</title>
      <table>
        <search>
          <query><![CDATA[
| datamodelsimple type=models
| eval data_model=coalesce(modelName, datamodel, model, title, name)
| where isnotnull(data_model) AND data_model!=""
| dedup data_model
| map maxsearches=300 search="
    | datamodelsimple type=objects datamodel=\"$data_model$\"
    | eval nodename=coalesce(objectName, nodename, object, name, title)
    | eval dataset=mvindex(split(nodename,\".\"),-1)
    | where isnotnull(nodename) AND nodename!=\"\"
    | dedup nodename
    | map maxsearches=300 search=\"| datamodel \\\\\\\"$data_model$\\\\\\\" \\\\\\\"$dataset$\\\\\\\" flat strict_fields=false summariesonly=$tok_summariesonly$ | eval selected_st=\\\"$tok_selected_st$\\\", st_filter=\\\"$tok_st_filter$\\\" | where (selected_st!=\\\"*\\\" AND sourcetype=selected_st) OR (selected_st=\\\"*\\\" AND (st_filter=\\\"*\\\" OR like(sourcetype, replace(st_filter,\\\"*\\\",\\\"%\\\")))) | stats count as events by sourcetype | eval data_model=\\\"$data_model$\\\", dataset=\\\"$dataset$\\\" | table sourcetype data_model dataset events\"
  "
| stats values(data_model) as data_models values(dataset) as datasets dc(data_model) as model_count dc(dataset) as dataset_count sum(events) as events by sourcetype
| sort - model_count - events
          ]]></query>
          <earliest>$tok_time.earliest$</earliest>
          <latest>$tok_time.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>

        <format type="color" field="model_count">
          <scale type="threshold">2,4</scale>
          <colorPalette type="list">[#65A637,#F7BC38,#D93F3C]</colorPalette>
        </format>

        <format type="number" field="events">
          <option name="precision">0</option>
        </format>
      </table>
    </panel>

    <panel>
      <title>Sample Events for Selected Dataset / Sourcetype</title>
      <table>
        <search>
          <query><![CDATA[
| datamodel "$tok_dm$" "$tok_dataset$" flat strict_fields=false summariesonly=$tok_summariesonly$
| eval selected_st="$tok_selected_st$", st_filter="$tok_st_filter$"
| where (selected_st!="*" AND sourcetype=selected_st) OR (selected_st="*" AND (st_filter="*" OR like(sourcetype, replace(st_filter,"*","%"))))
| head 20
          ]]></query>
          <earliest>$tok_time.earliest$</earliest>
          <latest>$tok_time.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Dataset Attributes Discovered</title>
      <table>
        <search>
          <query><![CDATA[
| datamodelsimple type=attributes datamodel="$tok_dm$" nodename="$tok_nodename$"
| eval field_name=coalesce(attributeName, attribute, field, name, title)
| where isnotnull(field_name) AND field_name!=""
| sort field_name
| table field_name
          ]]></query>
        </search>
        <option name="count">50</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
</form>
