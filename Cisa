index=cisa_pdns sourcetype=cisapdns:dns
| spath
| spath path=ResolverIPs{} output=answer_mv
| spath path=RData{}.data output=rdata_mv
| eval src=coalesce(SrcIP, src_ip, ClientIP, client_ip)
| eval dest=coalesce(DstIP, dest_ip, ResolverIP, resolver_ip)
| eval src_port=coalesce(SrcPort, src_port)
| eval dest_port=coalesce(DstPort, dest_port)
| eval query=lower(coalesce(QueryName, QName, Qname, FQDN, Domain, DomainName, HostName, Hostname, query))
| eval query_type=upper(coalesce(QueryTypeName, QTypeName, QueryType, QType, Type, RecordType, rrtype, query_type))
| eval record_type=coalesce(record_type, query_type)
| eval reply_code=coalesce(RCode, ResponseCode, rcode)
| eval transport=case(
    lower(Protocol)=="tls","tcp",
    lower(Protocol)=="tcp","tcp",
    lower(Protocol)=="udp","udp",
    true(), lower(Protocol)
  )
| eval dns_transport=lower(coalesce(Protocol, transport))
| eval answer=coalesce(mvjoin(answer_mv, "; "), mvjoin(rdata_mv, "; "), Answer, answer)
| eval answer_count=coalesce(AnswerCount, mvcount(answer_mv), mvcount(rdata_mv))
| eval query_count=coalesce(QueryCount, 1)
| eval authority_answer_count=coalesce(AuthorityCount, 0)
| eval additional_answer_count=coalesce(AdditionalCount, 0)
| eval transaction_id=coalesce(TransactionID, TxID, DNSID, QueryID)
| eval message_type=case(
    isnotnull(reply_code), "RESPONSE",
    answer_count>0, "RESPONSE",
    match(lower(coalesce(ResolverDecision,"")), "allow|block|deny"), "RESPONSE",
    true(), "QUERY"
  )
| eval action=case(
    match(lower(coalesce(ResolverDecision,"")), "allow"), "allowed",
    match(lower(coalesce(ResolverDecision,"")), "block|deny"), "blocked",
    reply_code=="0", "allowed",
    true(), "unknown"
  )
| eval vendor="CISA"
| eval product="Protective DNS"
| eval vendor_product="CISA Protective DNS"
| eval app="dns"
| table _time src src_port dest dest_port query query_type record_type answer answer_count reply_code message_type transport dns_transport action transaction_id vendor product vendor_product
