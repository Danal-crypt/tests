#!/usr/bin/env bash
# Pull EfOS/Maximo SystemOut/SystemErr logs to a Splunk-friendly monitor tree.
# Monitor ONLY: /app/cribl/efos_logs_maximo/data

set -u
set -o pipefail
umask 022

BASE_ROOT="/app/cribl/efos_logs_maximo"
DATA_ROOT="$BASE_ROOT/data"          # Splunk monitors this only
STATE_DIR="$BASE_ROOT/.state"        # Do not monitor
TMP_ROOT="$BASE_ROOT/.tmp"           # Do not monitor
STATE_FILE="$STATE_DIR/checkpoints.tsv"
LOCK_FILE="$STATE_DIR/pull.lock"
RUN_LOG="$STATE_DIR/pull.log"
SECRETS_FILE="$BASE_ROOT/.secrets"

# First-run behavior:
#   0 = download existing matching files on first sight
#   1 = checkpoint current remote sizes without downloading historical data
SEED_ONLY="${SEED_ONLY:-0}"

# Remote host config format:
# tag|host|port|user|password_env_var|comma,separated,remote,dirs
HOST_CONFIGS=(
  "srv1|100.108.6.245|37422|c_fdic_splunk|EFOS_PASS_SRV1|/shared_logs/PUI.CRON01,/shared_logs/PUI.MFI01,/shared_logs/PUI.RPT01,/shared_logs/PUI.UI01"
  "srv2|100.108.6.246|37422|c_fdic_splunk|EFOS_PASS_SRV2|/shared_logs/SUI1.CRON01,/shared_logs/SUI1.MFI01,/shared_logs/SUI1.RPT01,/shared_logs/SUI1.UI01"
  "test|100.108.6.228|37422|c_fdic_splunk|EFOS_PASS_TEST|/shared_logs/MXServer01"
  "de|100.108.6.213|37422|c_fdic_splunk|EFOS_PASS_DE|/shared_logs/MXServer01"
)

mkdir -p "$DATA_ROOT" "$STATE_DIR" "$TMP_ROOT"
touch "$STATE_FILE" "$RUN_LOG"
chmod 0750 "$BASE_ROOT" "$STATE_DIR" "$TMP_ROOT" 2>/dev/null || true
chmod 0640 "$STATE_FILE" "$RUN_LOG" 2>/dev/null || true

if [[ -f "$SECRETS_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$SECRETS_FILE"
fi

log() {
  printf '%s [%s] %s\n' "$(date -Is)" "$$" "$*" | tee -a "$RUN_LOG" >&2
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || { log "ERROR: missing required command: $1"; exit 1; }
}

need_cmd sshpass
need_cmd ssh
need_cmd tail
need_cmd find
need_cmd stat
need_cmd flock
need_cmd mktemp
need_cmd sed

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  log "Another pull is already running; exiting."
  exit 0
fi

shell_quote() {
  # Safely quote a string for the remote shell.
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

safe_name() {
  # Keep path parts Splunk/search friendly.
  printf '%s' "$1" | tr -c 'A-Za-z0-9._=-' '_'
}

log_type_for_file() {
  local base="$1"
  if [[ "$base" == SystemOut* ]]; then
    printf 'SystemOut'
  elif [[ "$base" == SystemErr* ]]; then
    printf 'SystemErr'
  else
    printf 'unknown'
  fi
}

make_dest_path() {
  local tag="$1" host="$2" remote_dir="$3" remote_file="$4" generation="$5"
  local app_dir base base_safe stem log_type dest_dir

  app_dir="$(safe_name "$(basename "$remote_dir")")"
  base="$(basename "$remote_file")"
  base_safe="$(safe_name "$base")"
  stem="${base_safe%.log}"
  log_type="$(log_type_for_file "$base")"

  dest_dir="$DATA_ROOT/remote_host=$tag/remote_ip=$host/app_dir=$app_dir/log_type=$log_type"
  mkdir -p "$dest_dir"
  printf '%s/%s.gen-%s.log' "$dest_dir" "$stem" "$generation"
}

ssh_base_args() {
  local port="$1"
  printf '%s\n' \
    -p "$port" \
    -o BatchMode=no \
    -o PreferredAuthentications=password,keyboard-interactive,publickey \
    -o StrictHostKeyChecking=accept-new \
    -o UserKnownHostsFile="$STATE_DIR/known_hosts" \
    -o ConnectTimeout=20 \
    -o ServerAliveInterval=15 \
    -o ServerAliveCountMax=2
}

remote_ssh() {
  local host="$1" port="$2" user="$3" pass="$4" cmd="$5"
  mapfile -t args < <(ssh_base_args "$port")
  SSHPASS="$pass" sshpass -e ssh -n "${args[@]}" "$user@$host" "$cmd"
}

list_remote_files() {
  local host="$1" port="$2" user="$3" pass="$4" remote_dir="$5"
  local qdir cmd
  qdir="$(shell_quote "$remote_dir")"
  cmd="find $qdir -maxdepth 1 -type f \\( -name 'SystemOut*.log' -o -name 'SystemErr*.log' \\) -printf '%p\t%s\t%T@\n' 2>/dev/null | sort"
  remote_ssh "$host" "$port" "$user" "$pass" "$cmd"
}

download_full() {
  local host="$1" port="$2" user="$3" pass="$4" remote_file="$5" dest_file="$6"
  local tmp qfile cmd bytes
  tmp="$(mktemp "$TMP_ROOT/full.XXXXXX")"
  qfile="$(shell_quote "$remote_file")"
  cmd="cat -- $qfile"

  if remote_ssh "$host" "$port" "$user" "$pass" "$cmd" > "$tmp"; then
    bytes="$(stat -c '%s' "$tmp")"
    mv -f "$tmp" "$dest_file"
    chmod 0644 "$dest_file"
    printf '%s' "$bytes"
    return 0
  fi

  rm -f "$tmp"
  return 1
}

append_new_bytes() {
  local host="$1" port="$2" user="$3" pass="$4" remote_file="$5" offset="$6" dest_file="$7"
  local tmp qfile cmd start bytes
  tmp="$(mktemp "$TMP_ROOT/chunk.XXXXXX")"
  qfile="$(shell_quote "$remote_file")"
  start=$((offset + 1))
  cmd="tail -c +$start -- $qfile"

  if remote_ssh "$host" "$port" "$user" "$pass" "$cmd" > "$tmp"; then
    bytes="$(stat -c '%s' "$tmp")"
    if (( bytes > 0 )); then
      cat "$tmp" >> "$dest_file"
      chmod 0644 "$dest_file"
    fi
    rm -f "$tmp"
    printf '%s' "$bytes"
    return 0
  fi

  rm -f "$tmp"
  return 1
}

# Checkpoint maps. Key is host|port|tag|remote_file.
declare -A CP_OFFSET CP_MTIME CP_DEST CP_GEN CP_LAST_SEEN

load_state() {
  local key offset mtime dest gen last_seen
  while IFS=$'\t' read -r key offset mtime dest gen last_seen; do
    [[ -z "${key:-}" || "$key" == \#* ]] && continue
    CP_OFFSET["$key"]="${offset:-0}"
    CP_MTIME["$key"]="${mtime:-0}"
    CP_DEST["$key"]="${dest:-}"
    CP_GEN["$key"]="${gen:-}"
    CP_LAST_SEEN["$key"]="${last_seen:-}"
  done < "$STATE_FILE"
}

save_state() {
  local tmp key
  tmp="$(mktemp "$STATE_DIR/checkpoints.XXXXXX")"
  for key in "${!CP_OFFSET[@]}"; do
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$key" \
      "${CP_OFFSET[$key]}" \
      "${CP_MTIME[$key]:-0}" \
      "${CP_DEST[$key]:-}" \
      "${CP_GEN[$key]:-}" \
      "${CP_LAST_SEEN[$key]:-}" \
      >> "$tmp"
  done
  sort -o "$tmp" "$tmp"
  mv -f "$tmp" "$STATE_FILE"
  chmod 0640 "$STATE_FILE" 2>/dev/null || true
}

process_remote_file() {
  local tag="$1" host="$2" port="$3" user="$4" pass="$5" remote_dir="$6" remote_file="$7" remote_size="$8" remote_mtime="$9"
  local key old_offset old_dest old_gen mtime_int now generation dest bytes new_offset reason dest_dir

  mtime_int="${remote_mtime%%.*}"
  now="$(date -u +%Y%m%dT%H%M%SZ)"
  key="$host|$port|$tag|$remote_file"

  old_offset="${CP_OFFSET[$key]:-}"
  old_dest="${CP_DEST[$key]:-}"
  old_gen="${CP_GEN[$key]:-}"

  # New remote file/path: create a new Splunk-visible generation file, or seed a checkpoint.
  if [[ -z "$old_offset" || -z "$old_dest" ]]; then
    generation="$now"
    dest="$(make_dest_path "$tag" "$host" "$remote_dir" "$remote_file" "$generation")"

    if [[ "$SEED_ONLY" == "1" ]]; then
      log "SEED $tag $remote_file size=$remote_size; checkpointing without download"
      CP_OFFSET["$key"]="$remote_size"
      CP_MTIME["$key"]="$mtime_int"
      CP_DEST["$key"]="$dest"
      CP_GEN["$key"]="$generation"
      CP_LAST_SEEN["$key"]="$now"
      save_state
      return 0
    fi

    log "FULL $tag $remote_file -> $dest"
    if bytes="$(download_full "$host" "$port" "$user" "$pass" "$remote_file" "$dest")"; then
      CP_OFFSET["$key"]="$bytes"
      CP_MTIME["$key"]="$mtime_int"
      CP_DEST["$key"]="$dest"
      CP_GEN["$key"]="$generation"
      CP_LAST_SEEN["$key"]="$now"
      save_state
      log "OK full $tag $(basename "$remote_file") bytes=$bytes"
    else
      log "ERROR full download failed: $tag $remote_file"
      return 1
    fi
    return 0
  fi

  # Remote file was truncated/re-created. Start a new local generation file so Splunk does not confuse it with old content.
  if (( remote_size < old_offset )); then
    generation="$now"
    dest="$(make_dest_path "$tag" "$host" "$remote_dir" "$remote_file" "$generation")"
    reason="remote size shrank from $old_offset to $remote_size"
    log "ROTATE/TRUNCATE $tag $remote_file ($reason); new generation -> $dest"
    if bytes="$(download_full "$host" "$port" "$user" "$pass" "$remote_file" "$dest")"; then
      CP_OFFSET["$key"]="$bytes"
      CP_MTIME["$key"]="$mtime_int"
      CP_DEST["$key"]="$dest"
      CP_GEN["$key"]="$generation"
      CP_LAST_SEEN["$key"]="$now"
      save_state
      log "OK new generation $tag $(basename "$remote_file") bytes=$bytes"
    else
      log "ERROR new-generation download failed: $tag $remote_file"
      return 1
    fi
    return 0
  fi

  # No new bytes. This also supports SEED_ONLY checkpoints where the local file has not been created yet.
  if (( remote_size == old_offset )); then
    CP_MTIME["$key"]="$mtime_int"
    CP_LAST_SEEN["$key"]="$now"
    save_state
    log "SKIP $tag $remote_file no new bytes size=$remote_size"
    return 0
  fi

  # Append only new bytes to the current local generation file. If the checkpoint was seeded,
  # the file may not exist yet; create it and write only post-checkpoint bytes.
  dest="$old_dest"
  if [[ ! -f "$dest" ]]; then
    dest_dir="$(dirname "$dest")"
    mkdir -p "$dest_dir"
    : > "$dest"
    chmod 0644 "$dest"
    log "CREATE $tag $remote_file local file did not exist; writing only bytes after checkpoint offset=$old_offset"
  fi

  log "APPEND $tag $remote_file offset=$old_offset remote_size=$remote_size -> $dest"
  if bytes="$(append_new_bytes "$host" "$port" "$user" "$pass" "$remote_file" "$old_offset" "$dest")"; then
    new_offset=$((old_offset + bytes))
    CP_OFFSET["$key"]="$new_offset"
    CP_MTIME["$key"]="$mtime_int"
    CP_DEST["$key"]="$dest"
    CP_GEN["$key"]="$old_gen"
    CP_LAST_SEEN["$key"]="$now"
    save_state
    log "OK append $tag $(basename "$remote_file") bytes=$bytes new_offset=$new_offset"
  else
    log "ERROR append failed: $tag $remote_file"
    return 1
  fi
}

load_state

for cfg in "${HOST_CONFIGS[@]}"; do
  IFS='|' read -r tag host port user pass_var dirs_csv <<< "$cfg"
  pass="${!pass_var:-}"

  if [[ -z "$pass" ]]; then
    log "ERROR: password variable $pass_var is not set for $tag/$host. Skipping host."
    continue
  fi

  IFS=',' read -r -a remote_dirs <<< "$dirs_csv"
  for remote_dir in "${remote_dirs[@]}"; do
    log "LIST $tag $host:$port $remote_dir"
    list_tmp="$(mktemp "$TMP_ROOT/list.XXXXXX")"
    if ! list_remote_files "$host" "$port" "$user" "$pass" "$remote_dir" > "$list_tmp"; then
      log "ERROR: remote listing failed: $tag $host:$port $remote_dir"
      rm -f "$list_tmp"
      continue
    fi

    while IFS=$'	' read -r remote_file remote_size remote_mtime; do
      [[ -z "${remote_file:-}" ]] && continue
      if [[ ! "$remote_size" =~ ^[0-9]+$ ]]; then
        log "WARN bad file size from remote listing: $tag $remote_file size=$remote_size"
        continue
      fi
      process_remote_file "$tag" "$host" "$port" "$user" "$pass" "$remote_dir" "$remote_file" "$remote_size" "$remote_mtime"
    done < "$list_tmp"
    rm -f "$list_tmp"
  done
done

# Keep monitored files readable, dirs traversable. Do not chmod +x log files.
find "$DATA_ROOT" -type d -exec chmod 0755 {} +
find "$DATA_ROOT" -type f -name '*.log' -exec chmod 0644 {} +
find "$TMP_ROOT" -type f -mtime +1 -delete 2>/dev/null || true

log "Done."
