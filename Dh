#!/usr/bin/env bash
# Pull EfOS/Maximo logs over SFTP into a Splunk-friendly monitor tree.
#
# Splunk should monitor ONLY:
#   /app/cribl/efos_logs_maximo/data
#
# This version is SFTP-native. It does NOT require remote shell access.
# It uses SFTP ls/get/reget instead of remote ssh find/cat/tail.

set -u
set -o pipefail
umask 022

BASE_ROOT="/app/cribl/efos_logs_maximo"
DATA_ROOT="$BASE_ROOT/data"          # Splunk monitors this only
STATE_DIR="$BASE_ROOT/.state"        # Do not monitor
TMP_ROOT="$BASE_ROOT/.tmp"           # Do not monitor
STATE_FILE="$STATE_DIR/checkpoints.tsv"
LOCK_FILE="$STATE_DIR/pull.lock"
RUN_LOG="$STATE_DIR/pull.log"
SECRETS_FILE="$BASE_ROOT/.secrets"

SFTP_BIN="${SFTP_BIN:-sftp}"
SSHPASS_BIN="${SSHPASS_BIN:-sshpass}"
STRICT_HOST_KEY_CHECKING="${STRICT_HOST_KEY_CHECKING:-accept-new}"

# First-run behavior:
#   0 = download existing matching files on first sight
#   1 = checkpoint current remote sizes without downloading historical data
SEED_ONLY="${SEED_ONLY:-0}"

# Remote host config format:
# tag|host|port|user|password_env_var|comma,separated,remote,dirs
HOST_CONFIGS=(
  "srv1|100.108.6.245|37422|c_fdic_splunk|EFOS_PASS_SRV1|/shared_logs/PUI.CRON01,/shared_logs/PUI.MFI01,/shared_logs/PUI.RPT01,/shared_logs/PUI.UI01"
  "srv2|100.108.6.246|37422|c_fdic_splunk|EFOS_PASS_SRV2|/shared_logs/SUI1.CRON01,/shared_logs/SUI1.MFI01,/shared_logs/SUI1.RPT01,/shared_logs/SUI1.UI01"
  "test|100.108.6.228|37422|c_fdic_splunk|EFOS_PASS_TEST|/shared_logs/MXServer01"
  "de|100.108.6.213|37422|c_fdic_splunk|EFOS_PASS_DE|/shared_logs/MXServer01"
)

mkdir -p "$DATA_ROOT" "$STATE_DIR" "$TMP_ROOT"
touch "$STATE_FILE" "$RUN_LOG"
chmod 0750 "$BASE_ROOT" "$STATE_DIR" "$TMP_ROOT" 2>/dev/null || true
chmod 0640 "$STATE_FILE" "$RUN_LOG" 2>/dev/null || true

if [[ -f "$SECRETS_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$SECRETS_FILE"
fi

log() {
  printf '%s [%s] %s\n' "$(date -Is)" "$$" "$*" | tee -a "$RUN_LOG" >&2
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || { log "ERROR: missing required command: $1"; exit 1; }
}

need_cmd "$SSHPASS_BIN"
need_cmd "$SFTP_BIN"
need_cmd awk
need_cmd find
need_cmd flock
need_cmd mktemp
need_cmd stat
need_cmd sed
need_cmd sort
need_cmd tail
need_cmd truncate

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  log "Another pull is already running; exiting."
  exit 0
fi

safe_name() {
  # Keep path parts Splunk/search friendly.
  printf '%s' "$1" | tr -c 'A-Za-z0-9._=-' '_'
}

log_type_for_file() {
  local base="$1"
  if [[ "$base" == SystemOut* ]]; then
    printf 'SystemOut'
  elif [[ "$base" == SystemErr* ]]; then
    printf 'SystemErr'
  else
    printf 'unknown'
  fi
}

make_dest_path() {
  local tag="$1" host="$2" remote_dir="$3" remote_file="$4" generation="$5"
  local app_dir base base_safe stem log_type dest_dir

  app_dir="$(safe_name "$(basename "$remote_dir")")"
  base="$(basename "$remote_file")"
  base_safe="$(safe_name "$base")"
  stem="${base_safe%.log}"
  log_type="$(log_type_for_file "$base")"

  dest_dir="$DATA_ROOT/remote_host=$tag/remote_ip=$host/app_dir=$app_dir/log_type=$log_type"
  mkdir -p "$dest_dir"
  printf '%s/%s.gen-%s.log' "$dest_dir" "$stem" "$generation"
}

sftp_path() {
  # These paths currently have no spaces. This keeps simple escaping if a space appears later.
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/ /\\ /g'
}

sftp_run() {
  local host="$1" port="$2" user="$3" pass="$4" batch_file="$5" stdout_file="$6" stderr_file="$7"

  SSHPASS="$pass" "$SSHPASS_BIN" -e "$SFTP_BIN" \
    -q \
    -b "$batch_file" \
    -P "$port" \
    -oBatchMode=no \
    -oPreferredAuthentications=password,keyboard-interactive,publickey \
    -oStrictHostKeyChecking="$STRICT_HOST_KEY_CHECKING" \
    -oUserKnownHostsFile="$STATE_DIR/known_hosts" \
    -oConnectTimeout=20 \
    -oServerAliveInterval=15 \
    -oServerAliveCountMax=2 \
    "$user@$host" >"$stdout_file" 2>"$stderr_file"
}

log_sftp_error() {
  local err_file="$1"
  if [[ -s "$err_file" ]]; then
    log "SFTP stderr follows:"
    sed 's/^/  /' "$err_file" | tail -40 | tee -a "$RUN_LOG" >&2
  fi
}

list_remote_files() {
  local host="$1" port="$2" user="$3" pass="$4" remote_dir="$5"
  local batch out err rc edir

  batch="$(mktemp "$TMP_ROOT/sftp-list-batch.XXXXXX")"
  out="$(mktemp "$TMP_ROOT/sftp-list-out.XXXXXX")"
  err="$(mktemp "$TMP_ROOT/sftp-list-err.XXXXXX")"
  edir="$(sftp_path "$remote_dir")"

  {
    printf 'cd %s\n' "$edir"
    # Leading '-' tells sftp not to fail the whole batch if a glob has no matches.
    printf -- '-ls -l SystemOut*.log\n'
    printf -- '-ls -l SystemErr*.log\n'
    printf 'bye\n'
  } > "$batch"

  sftp_run "$host" "$port" "$user" "$pass" "$batch" "$out" "$err"
  rc=$?
  if (( rc != 0 )); then
    log_sftp_error "$err"
    rm -f "$batch" "$out" "$err"
    return "$rc"
  fi

  # OpenSSH sftp long-listing shape is normally:
  # -rw-r--r--    1 user group      12345 Jul  1 06:10 SystemOut.log
  # Size is field 5, filename is the final field. Maximo log names should not contain spaces.
  awk -v dir="$remote_dir" '
    $1 ~ /^-/ {
      size=$5
      name=$NF
      if (size ~ /^[0-9]+$/ && name ~ /^System(Out|Err).*\.log$/) {
        print dir "/" name "\t" size "\t" $0
      }
    }
  ' "$out"

  rm -f "$batch" "$out" "$err"
  return 0
}

sftp_get_full() {
  local host="$1" port="$2" user="$3" pass="$4" remote_file="$5" dest_file="$6"
  local batch out err tmp rfile dfile bytes rc

  batch="$(mktemp "$TMP_ROOT/sftp-get-batch.XXXXXX")"
  out="$(mktemp "$TMP_ROOT/sftp-get-out.XXXXXX")"
  err="$(mktemp "$TMP_ROOT/sftp-get-err.XXXXXX")"
  tmp="$(mktemp "$TMP_ROOT/full.XXXXXX")"
  rm -f "$tmp"

  rfile="$(sftp_path "$remote_file")"
  dfile="$(sftp_path "$tmp")"

  {
    printf 'get %s %s\n' "$rfile" "$dfile"
    printf 'bye\n'
  } > "$batch"

  sftp_run "$host" "$port" "$user" "$pass" "$batch" "$out" "$err"
  rc=$?
  if (( rc != 0 )); then
    log_sftp_error "$err"
    rm -f "$batch" "$out" "$err" "$tmp"
    return "$rc"
  fi

  bytes="$(stat -c '%s' "$tmp" 2>/dev/null || printf '0')"
  mv -f "$tmp" "$dest_file"
  chmod 0644 "$dest_file"

  rm -f "$batch" "$out" "$err"
  printf '%s' "$bytes"
  return 0
}

sftp_reget_from_offset_append() {
  local host="$1" port="$2" user="$3" pass="$4" remote_file="$5" offset="$6" dest_file="$7"
  local batch out err tmp rfile tfile rc new_size start

  batch="$(mktemp "$TMP_ROOT/sftp-reget-batch.XXXXXX")"
  out="$(mktemp "$TMP_ROOT/sftp-reget-out.XXXXXX")"
  err="$(mktemp "$TMP_ROOT/sftp-reget-err.XXXXXX")"
  tmp="$(mktemp "$TMP_ROOT/reget-offset.XXXXXX")"

  # Make a sparse temp file whose logical size equals the checkpoint offset.
  # sftp reget resumes from that size, so only remote bytes after the checkpoint transfer.
  : > "$tmp"
  truncate -s "$offset" "$tmp"

  rfile="$(sftp_path "$remote_file")"
  tfile="$(sftp_path "$tmp")"

  {
    printf 'reget %s %s\n' "$rfile" "$tfile"
    printf 'bye\n'
  } > "$batch"

  sftp_run "$host" "$port" "$user" "$pass" "$batch" "$out" "$err"
  rc=$?
  if (( rc != 0 )); then
    log_sftp_error "$err"
    rm -f "$batch" "$out" "$err" "$tmp"
    return "$rc"
  fi

  new_size="$(stat -c '%s' "$tmp")"
  if (( new_size > offset )); then
    start=$((offset + 1))
    tail -c +"$start" "$tmp" >> "$dest_file"
    chmod 0644 "$dest_file"
  fi

  rm -f "$batch" "$out" "$err" "$tmp"
  printf '%s' "$new_size"
  return 0
}

# Checkpoint maps. Key is tag|host|port|remote_file.
declare -A CP_OFFSET CP_LISTING CP_DEST CP_GEN CP_LAST_SEEN

load_state() {
  local key offset listing dest gen last_seen
  while IFS=$'\t' read -r key offset listing dest gen last_seen; do
    [[ -z "${key:-}" || "$key" == \#* ]] && continue
    CP_OFFSET["$key"]="${offset:-0}"
    CP_LISTING["$key"]="${listing:-}"
    CP_DEST["$key"]="${dest:-}"
    CP_GEN["$key"]="${gen:-}"
    CP_LAST_SEEN["$key"]="${last_seen:-}"
  done < "$STATE_FILE"
}

save_state() {
  local tmp key
  tmp="$(mktemp "$STATE_DIR/checkpoints.XXXXXX")"
  for key in "${!CP_OFFSET[@]}"; do
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$key" \
      "${CP_OFFSET[$key]}" \
      "${CP_LISTING[$key]:-}" \
      "${CP_DEST[$key]:-}" \
      "${CP_GEN[$key]:-}" \
      "${CP_LAST_SEEN[$key]:-}" \
      >> "$tmp"
  done
  sort -o "$tmp" "$tmp"
  mv -f "$tmp" "$STATE_FILE"
  chmod 0640 "$STATE_FILE" 2>/dev/null || true
}

process_remote_file() {
  local tag="$1" host="$2" port="$3" user="$4" pass="$5" remote_dir="$6" remote_file="$7" remote_size="$8" listing="$9"
  local key now generation dest old_offset old_dest old_gen local_size bytes new_size dest_dir

  now="$(date -u +%Y%m%dT%H%M%SZ)"
  key="$tag|$host|$port|$remote_file"

  old_offset="${CP_OFFSET[$key]:-}"
  old_dest="${CP_DEST[$key]:-}"
  old_gen="${CP_GEN[$key]:-}"

  # Brand-new checkpoint entry.
  if [[ -z "$old_offset" || -z "$old_dest" ]]; then
    generation="$now"
    dest="$(make_dest_path "$tag" "$host" "$remote_dir" "$remote_file" "$generation")"

    if [[ "$SEED_ONLY" == "1" ]]; then
      log "SEED $tag $remote_file size=$remote_size; checkpointing without download"
      CP_OFFSET["$key"]="$remote_size"
      CP_LISTING["$key"]="$listing"
      CP_DEST["$key"]="$dest"
      CP_GEN["$key"]="$generation"
      CP_LAST_SEEN["$key"]="$now"
      save_state
      return 0
    fi

    log "FULL $tag $remote_file -> $dest"
    if bytes="$(sftp_get_full "$host" "$port" "$user" "$pass" "$remote_file" "$dest")"; then
      CP_OFFSET["$key"]="$bytes"
      CP_LISTING["$key"]="$listing"
      CP_DEST["$key"]="$dest"
      CP_GEN["$key"]="$generation"
      CP_LAST_SEEN["$key"]="$now"
      save_state
      log "OK full $tag $(basename "$remote_file") bytes=$bytes"
      return 0
    fi

    log "ERROR full download failed: $tag $remote_file"
    return 1
  fi

  dest="$old_dest"

  if [[ -f "$dest" ]]; then
    local_size="$(stat -c '%s' "$dest")"
  else
    local_size=0
  fi

  # The checkpoint is the source of truth. The local file may be smaller when SEED_ONLY was used
  # or when the file was recreated after deletion.
  if [[ -f "$dest" && "$local_size" -gt "$old_offset" ]]; then
    log "WARN local file is larger than checkpoint for $tag $remote_file: checkpoint=$old_offset local=$local_size; advancing checkpoint"
    old_offset="$local_size"
  fi

  # Remote file was truncated/re-created. Start a new local generation file so Splunk gets a clean source.
  if (( remote_size < old_offset )); then
    generation="$now"
    dest="$(make_dest_path "$tag" "$host" "$remote_dir" "$remote_file" "$generation")"
    log "ROTATE/TRUNCATE $tag $remote_file remote_size=$remote_size old_offset=$old_offset; new generation -> $dest"

    if bytes="$(sftp_get_full "$host" "$port" "$user" "$pass" "$remote_file" "$dest")"; then
      CP_OFFSET["$key"]="$bytes"
      CP_LISTING["$key"]="$listing"
      CP_DEST["$key"]="$dest"
      CP_GEN["$key"]="$generation"
      CP_LAST_SEEN["$key"]="$now"
      save_state
      log "OK new generation $tag $(basename "$remote_file") bytes=$bytes"
      return 0
    fi

    log "ERROR new-generation download failed: $tag $remote_file"
    return 1
  fi

  # No new bytes.
  if (( remote_size == old_offset )); then
    CP_OFFSET["$key"]="$old_offset"
    CP_LISTING["$key"]="$listing"
    CP_LAST_SEEN["$key"]="$now"
    save_state
    log "SKIP $tag $remote_file no new bytes size=$remote_size"
    return 0
  fi

  # Append only missing bytes using SFTP reget from a sparse temp checkpoint file.
  # This keeps the monitored Splunk file clean while still transferring only remote bytes after old_offset.
  if [[ ! -f "$dest" ]]; then
    dest_dir="$(dirname "$dest")"
    mkdir -p "$dest_dir"
    : > "$dest"
    chmod 0644 "$dest"
    log "CREATE $tag $remote_file local destination was missing; writing only bytes after checkpoint offset=$old_offset"
  fi

  log "REGET $tag $remote_file checkpoint_offset=$old_offset remote_size=$remote_size -> $dest"
  if new_size="$(sftp_reget_from_offset_append "$host" "$port" "$user" "$pass" "$remote_file" "$old_offset" "$dest")"; then
    CP_OFFSET["$key"]="$new_size"
    CP_LISTING["$key"]="$listing"
    CP_DEST["$key"]="$dest"
    CP_GEN["$key"]="$old_gen"
    CP_LAST_SEEN["$key"]="$now"
    save_state

    if (( new_size < remote_size )); then
      log "WARN reget completed but checkpoint is still smaller than listed remote size: checkpoint=$new_size remote=$remote_size"
    else
      log "OK reget $tag $(basename "$remote_file") added=$((new_size - old_offset)) new_checkpoint=$new_size"
    fi
    return 0
  fi

  log "ERROR reget failed: $tag $remote_file"
  return 1
}

load_state

for cfg in "${HOST_CONFIGS[@]}"; do
  IFS='|' read -r tag host port user pass_var dirs_csv <<< "$cfg"
  pass="${!pass_var:-}"

  if [[ -z "$pass" ]]; then
    log "ERROR: password variable $pass_var is not set for $tag/$host. Skipping host."
    continue
  fi

  IFS=',' read -r -a remote_dirs <<< "$dirs_csv"
  for remote_dir in "${remote_dirs[@]}"; do
    log "LIST $tag $host:$port $remote_dir"
    list_tmp="$(mktemp "$TMP_ROOT/list.XXXXXX")"

    if ! list_remote_files "$host" "$port" "$user" "$pass" "$remote_dir" > "$list_tmp"; then
      log "ERROR: remote listing failed: $tag $host:$port $remote_dir"
      rm -f "$list_tmp"
      continue
    fi

    if [[ ! -s "$list_tmp" ]]; then
      log "INFO no matching SystemOut/SystemErr logs found: $tag $remote_dir"
    fi

    while IFS=$'\t' read -r remote_file remote_size listing; do
      [[ -z "${remote_file:-}" ]] && continue
      if [[ ! "$remote_size" =~ ^[0-9]+$ ]]; then
        log "WARN bad file size from remote listing: $tag $remote_file size=$remote_size"
        continue
      fi
      process_remote_file "$tag" "$host" "$port" "$user" "$pass" "$remote_dir" "$remote_file" "$remote_size" "$listing"
    done < "$list_tmp"

    rm -f "$list_tmp"
  done
done

# Keep monitored files readable, dirs traversable. Do not chmod +x log files.
find "$DATA_ROOT" -type d -exec chmod 0755 {} +
find "$DATA_ROOT" -type f -name '*.log' -exec chmod 0644 {} +
find "$TMP_ROOT" -type f -mtime +1 -delete 2>/dev/null || true

log "Done."
