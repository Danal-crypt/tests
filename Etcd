#!/usr/bin/env bash

set -euo pipefail

ETCD_DIR="/opt/etcd-v3.6.5"
BACKUP_DIR="/opt/etcd-v3.6.5/backups"

CACERT="/opt/splunk/etc/apps/splunk_app_db_connect/cert.pem"
CERT="/opt/splunk/etc/apps/splunk_app_db_connect/cert.pem"
KEY="/opt/splunk/etc/apps/splunk_app_db_connect/key.key"

ETCD_USER="user"
ETCD_PASS="pass"

ETCD_PORT="2379"
COMMAND_TIMEOUT="20s"
QUOTA_BACKEND_BYTES="2147483648"

ETCDCTL_BIN="${ETCD_DIR}/etcdctl"

emit_error_json() {
python3 - <<PY
import json, socket, time
print(json.dumps({
    "event_type": "etcd_node_check",
    "status": "error",
    "severity": "critical",
    "check_host": socket.gethostname(),
    "error": "$1",
    "timestamp_epoch": int(time.time())
}, separators=(",", ":")))
PY
}

if [[ ! -x "$ETCDCTL_BIN" ]]; then
    emit_error_json "etcdctl not found or not executable at $ETCDCTL_BIN"
    exit 1
fi

LOCAL_HOSTNAME="$(hostname -s 2>/dev/null || hostname)"
LOCAL_IP="$(hostname -I 2>/dev/null | tr ' ' '\n' | awk '/^10\./ {print; exit}')"

if [[ -z "$LOCAL_IP" ]]; then
    emit_error_json "no 10.x IP found from hostname -I"
    exit 1
fi

ENDPOINT="https://${LOCAL_IP}:${ETCD_PORT}"
NOW_EPOCH="$(date +%s)"

LATEST_BACKUP_FILE=""
LATEST_BACKUP_EPOCH=""
LATEST_BACKUP_AGE_SEC=""
LATEST_BACKUP_SIZE_BYTES=""

if [[ -d "$BACKUP_DIR" ]]; then
    LATEST_BACKUP_FILE="$(find "$BACKUP_DIR" -maxdepth 1 -type f \( -name 'backup_db_*.db' -o -name '*.db' \) -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -1 | cut -d' ' -f2-)"
    if [[ -n "$LATEST_BACKUP_FILE" && -f "$LATEST_BACKUP_FILE" ]]; then
        LATEST_BACKUP_EPOCH="$(stat -c %Y "$LATEST_BACKUP_FILE" 2>/dev/null || true)"
        LATEST_BACKUP_SIZE_BYTES="$(stat -c %s "$LATEST_BACKUP_FILE" 2>/dev/null || true)"
        if [[ -n "$LATEST_BACKUP_EPOCH" ]]; then
            LATEST_BACKUP_AGE_SEC="$((NOW_EPOCH - LATEST_BACKUP_EPOCH))"
        fi
    fi
fi

HEALTH_RAW="$("$ETCDCTL_BIN" \
  --endpoints="$ENDPOINT" \
  --cacert="$CACERT" \
  --cert="$CERT" \
  --key="$KEY" \
  --user="${ETCD_USER}:${ETCD_PASS}" \
  --command-timeout="$COMMAND_TIMEOUT" \
  endpoint health -w json 2>&1 || true)"

STATUS_RAW="$("$ETCDCTL_BIN" \
  --endpoints="$ENDPOINT" \
  --cacert="$CACERT" \
  --cert="$CERT" \
  --key="$KEY" \
  --user="${ETCD_USER}:${ETCD_PASS}" \
  --command-timeout="$COMMAND_TIMEOUT" \
  endpoint status -w json 2>&1 || true)"

ALARM_RAW="$("$ETCDCTL_BIN" \
  --endpoints="$ENDPOINT" \
  --cacert="$CACERT" \
  --cert="$CERT" \
  --key="$KEY" \
  --user="${ETCD_USER}:${ETCD_PASS}" \
  --command-timeout="$COMMAND_TIMEOUT" \
  alarm list 2>&1 || true)"

export LOCAL_HOSTNAME LOCAL_IP ENDPOINT NOW_EPOCH QUOTA_BACKEND_BYTES
export LATEST_BACKUP_FILE LATEST_BACKUP_EPOCH LATEST_BACKUP_AGE_SEC LATEST_BACKUP_SIZE_BYTES
export HEALTH_RAW STATUS_RAW ALARM_RAW

python3 - <<'PY'
import os
import json
import re

def parse_json_loose(raw):
    raw = (raw or "").strip()
    if not raw:
        return None, "empty output"
    try:
        return json.loads(raw), None
    except Exception:
        pass
    lines = [line.strip() for line in raw.splitlines() if line.strip()]
    for line in reversed(lines):
        if line.startswith("{") or line.startswith("["):
            try:
                return json.loads(line), None
            except Exception:
                continue
    return None, f"unable to parse json from raw output: {raw[:1000]}"

def first_obj(x):
    if isinstance(x, list) and x:
        return x[0]
    if isinstance(x, dict):
        return x
    return {}

def normalize_bool(v):
    if isinstance(v, bool):
        return v
    if isinstance(v, str):
        s = v.strip().lower()
        if s == "true":
            return True
        if s == "false":
            return False
    return None

def to_int(v):
    if v is None or v == "":
        return None
    try:
        return int(v)
    except Exception:
        try:
            return int(float(v))
        except Exception:
            return None

def bytes_to_mb(v):
    if v is None:
        return None
    try:
        return round(v / 1024 / 1024, 2)
    except Exception:
        return None

def stringify_nulls(obj):
    if isinstance(obj, dict):
        return {k: stringify_nulls(v) for k, v in obj.items()}
    if isinstance(obj, list):
        return [stringify_nulls(v) for v in obj]
    if obj is None:
        return "null"
    return obj

local_hostname = os.environ.get("LOCAL_HOSTNAME", "unknown")
local_ip = os.environ.get("LOCAL_IP", "unknown")
endpoint = os.environ.get("ENDPOINT", "")
now_epoch = int(os.environ.get("NOW_EPOCH", "0") or 0)
quota_backend_bytes = to_int(os.environ.get("QUOTA_BACKEND_BYTES", ""))

latest_backup_file = os.environ.get("LATEST_BACKUP_FILE", "")
latest_backup_epoch = to_int(os.environ.get("LATEST_BACKUP_EPOCH", ""))
latest_backup_age_sec = to_int(os.environ.get("LATEST_BACKUP_AGE_SEC", ""))
latest_backup_size_bytes = to_int(os.environ.get("LATEST_BACKUP_SIZE_BYTES", ""))

health_raw = os.environ.get("HEALTH_RAW", "")
status_raw = os.environ.get("STATUS_RAW", "")
alarm_raw = os.environ.get("ALARM_RAW", "")

health_data, health_err = parse_json_loose(health_raw)
status_data, status_err = parse_json_loose(status_raw)

h = first_obj(health_data)
s = first_obj(status_data)

event = {
    "event_type": "etcd_node_check",
    "status": "ok",
    "severity": "info",

    "check_host": local_hostname,
    "check_ip": local_ip,
    "endpoint": endpoint,
    "timestamp_epoch": now_epoch,

    "quota_backend_bytes": quota_backend_bytes,
    "quota_backend_mb": bytes_to_mb(quota_backend_bytes),

    "health": None,
    "health_state": "unknown",
    "health_took": "",
    "health_error": "",

    "version": "",
    "cluster_id": "",
    "member_id": "",
    "leader_id": "",
    "is_leader": None,
    "is_learner": None,
    "node_role": "unknown",

    "revision": None,
    "raft_term": None,
    "raft_index": None,
    "raft_applied_index": None,

    "db_size_bytes": None,
    "db_size_mb": None,
    "db_size_in_use_bytes": None,
    "db_size_in_use_mb": None,

    "db_file_in_use_pct": None,
    "db_quota_used_pct": None,
    "db_quota_in_use_pct": None,
    "db_space_state": "unknown",

    "status_errors": [],
    "status_errors_count": 0,
    "status_errors_text": "",
    "has_status_errors": False,

    "has_alarm": False,
    "alarm_count": 0,
    "alarms": [],
    "alarms_text": "",

    "latest_backup_file": latest_backup_file if latest_backup_file else None,
    "latest_backup_epoch": latest_backup_epoch,
    "latest_backup_age_sec": latest_backup_age_sec,
    "latest_backup_age_hr": round(latest_backup_age_sec / 3600, 2) if latest_backup_age_sec is not None else None,
    "latest_backup_size_bytes": latest_backup_size_bytes,
    "latest_backup_size_mb": bytes_to_mb(latest_backup_size_bytes),
    "backup_state": "unknown",

    "notable": [],
    "notable_text": "",
    "is_issue": False
}

if health_err:
    event["notable"].append("health_parse_failed")
    event["health_error"] = health_err
else:
    event["health"] = normalize_bool(h.get("Health", h.get("health")))
    event["health_took"] = h.get("Took", h.get("took", ""))
    event["health_error"] = h.get("Error", h.get("error", ""))

if event["health"] is None and event["health_error"] == "":
    hr = health_raw.lower()
    if '"health":true' in hr or '"health": true' in hr:
        event["health"] = True
    elif '"health":false' in hr or '"health": false' in hr:
        event["health"] = False

if event["health"] is True:
    event["health_state"] = "healthy"
elif event["health"] is False:
    event["health_state"] = "unhealthy"

if status_err:
    event["notable"].append("status_parse_failed")
    if not event["health_error"]:
        event["health_error"] = status_err
else:
    status_obj = s.get("Status", s.get("status", {}))
    if not isinstance(status_obj, dict):
        status_obj = {}

    header = status_obj.get("header", status_obj.get("Header", {}))
    if not isinstance(header, dict):
        header = {}

    event["version"] = (
        status_obj.get("version")
        or status_obj.get("Version")
        or s.get("version")
        or s.get("Version")
        or ""
    )

    event["cluster_id"] = str(header.get("cluster_id", header.get("clusterId", "")) or "")
    event["member_id"] = str(header.get("member_id", header.get("memberId", "")) or "")
    event["revision"] = to_int(header.get("revision", header.get("Revision")))

    event["leader_id"] = str(
        status_obj.get("leader", status_obj.get("leader_id", status_obj.get("leaderId", "")))
        or ""
    )

    if event["member_id"] != "" and event["leader_id"] != "":
        event["is_leader"] = (event["member_id"] == event["leader_id"])
        event["node_role"] = "leader" if event["is_leader"] else "follower"

    event["is_learner"] = normalize_bool(status_obj.get("isLearner", status_obj.get("is_learner")))
    event["db_size_bytes"] = to_int(status_obj.get("dbSize", status_obj.get("db_size")))
    event["db_size_in_use_bytes"] = to_int(status_obj.get("dbSizeInUse", status_obj.get("db_size_in_use")))
    event["raft_term"] = to_int(status_obj.get("raftTerm", status_obj.get("raft_term", header.get("raft_term"))))
    event["raft_index"] = to_int(status_obj.get("raftIndex", status_obj.get("raft_index")))
    event["raft_applied_index"] = to_int(status_obj.get("raftAppliedIndex", status_obj.get("raft_applied_index")))

    event["db_size_mb"] = bytes_to_mb(event["db_size_bytes"])
    event["db_size_in_use_mb"] = bytes_to_mb(event["db_size_in_use_bytes"])

    if event["db_size_bytes"] is not None and event["db_size_in_use_bytes"] is not None and event["db_size_bytes"] > 0:
        event["db_file_in_use_pct"] = round((event["db_size_in_use_bytes"] / event["db_size_bytes"]) * 100, 2)

    if quota_backend_bytes and quota_backend_bytes > 0:
        if event["db_size_bytes"] is not None:
            event["db_quota_used_pct"] = round((event["db_size_bytes"] / quota_backend_bytes) * 100, 2)
        if event["db_size_in_use_bytes"] is not None:
            event["db_quota_in_use_pct"] = round((event["db_size_in_use_bytes"] / quota_backend_bytes) * 100, 2)

    errs = s.get("Errors", s.get("errors", []))
    if isinstance(errs, list):
        event["status_errors"] = [str(x) for x in errs if str(x) != ""]
    elif errs:
        event["status_errors"] = [str(errs)]

event["status_errors_count"] = len(event["status_errors"])
event["has_status_errors"] = event["status_errors_count"] > 0
event["status_errors_text"] = ", ".join(event["status_errors"])

member_id_lower = event["member_id"].lower()
alarms = []

for line in alarm_raw.splitlines():
    line = line.strip()
    if not line:
        continue
    m = re.search(r'memberID:([0-9a-fx]+)\s+alarm:([A-Z_]+)', line, re.I)
    if m and member_id_lower and m.group(1).lower() == member_id_lower:
        alarms.append(m.group(2))

event["alarms"] = alarms
event["alarm_count"] = len(alarms)
event["has_alarm"] = event["alarm_count"] > 0
event["alarms_text"] = ", ".join(alarms)

if event["db_quota_in_use_pct"] is None:
    event["db_space_state"] = "unknown"
elif event["db_quota_in_use_pct"] >= 95:
    event["db_space_state"] = "critical"
elif event["db_quota_in_use_pct"] >= 85:
    event["db_space_state"] = "high"
elif event["db_quota_in_use_pct"] >= 70:
    event["db_space_state"] = "warning"
else:
    event["db_space_state"] = "ok"

if event["latest_backup_age_sec"] is None:
    event["backup_state"] = "missing"
elif event["latest_backup_age_sec"] > 86400:
    event["backup_state"] = "stale"
else:
    event["backup_state"] = "ok"

if event["health"] is False:
    event["severity"] = "critical"
    event["notable"].append("endpoint_unhealthy")

if event["health_error"]:
    if event["severity"] != "critical":
        event["severity"] = "high"
    event["notable"].append("health_error_present")

if event["has_status_errors"]:
    if event["severity"] != "critical":
        event["severity"] = "high"
    event["notable"].append("status_errors_present")

if event["has_alarm"]:
    if event["severity"] != "critical":
        event["severity"] = "high"
    event["notable"].append("alarms_present")

if event["db_quota_in_use_pct"] is not None:
    if event["db_quota_in_use_pct"] >= 95:
        event["severity"] = "critical"
        event["notable"].append("db_space_critical")
    elif event["db_quota_in_use_pct"] >= 85:
        if event["severity"] not in ("critical",):
            event["severity"] = "high"
        event["notable"].append("db_space_high")
    elif event["db_quota_in_use_pct"] >= 70:
        if event["severity"] == "info":
            event["severity"] = "medium"
        event["notable"].append("db_space_warning")

if event["latest_backup_age_sec"] is None:
    if event["severity"] == "info":
        event["severity"] = "medium"
    event["notable"].append("backup_missing")
elif event["latest_backup_age_sec"] > 604800:
    if event["severity"] == "info":
        event["severity"] = "medium"
    event["notable"].append("backup_older_than_7d")

if event["health"] is None and event["revision"] is None:
    event["status"] = "error"
    event["severity"] = "critical"
    event["notable"].append("no_valid_etcd_data_returned")

event["notable"] = list(dict.fromkeys(event["notable"]))
event["notable_text"] = ", ".join(event["notable"])

event["is_issue"] = (
    event["status"] != "ok"
    or event["health"] is False
    or event["has_alarm"]
    or event["has_status_errors"]
    or event["backup_state"] in ("missing", "stale")
    or event["db_space_state"] in ("warning", "high", "critical")
)

event = stringify_nulls(event)
print(json.dumps(event, separators=(",", ":")))
PY
