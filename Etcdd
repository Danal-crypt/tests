<form version="1.1">
  <label>etcd Node Health Overview</label>
  <description>Cluster health, backup freshness, raft/revision lag, and recent issues for etcd self-reporting node health events.</description>

  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="time_tok">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>

    <input type="dropdown" token="node_tok" searchWhenChanged="true">
      <label>Node</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>check_host</fieldForLabel>
      <fieldForValue>check_host</fieldForValue>
      <search>
        <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| stats count by check_host
| sort check_host
        ]]></query>
        <earliest>$time_tok.earliest$</earliest>
        <latest>$time_tok.latest$</latest>
      </search>
    </input>
  </fieldset>

  <row>
    <panel>
      <single>
        <title>Reporting Nodes (Seen in Last 10m)</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(_time) as last_seen by check_host
| eval age_sec=now()-last_seen
| where age_sec<=600
| stats count as reporting_nodes
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <single>
        <title>Healthy Nodes (Latest Event Healthy + Seen in Last 10m)</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(_time) as last_seen latest(health) as health by check_host
| eval age_sec=now()-last_seen
| eval healthy=if(age_sec<=600 AND health=true,1,0)
| stats sum(healthy) as healthy_nodes
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <single>
        <title>Nodes with Active Alarms</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(has_alarm) as has_alarm by check_host
| where has_alarm=true
| stats count as alarmed_nodes
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>

    <panel>
      <single>
        <title>Nodes with Missing / Stale Backups (&gt; 24h)</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(latest_backup_age_sec) as backup_age_sec by check_host
| eval stale_backup=if(isnull(backup_age_sec) OR backup_age_sec>86400,1,0)
| stats sum(stale_backup) as stale_backup_nodes
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <table>
        <title>Current Leader</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(_time) as last_seen latest(is_leader) as is_leader latest(leader_id) as leader_id latest(revision) as revision latest(raft_term) as raft_term latest(version) as version by check_host
| where is_leader=true
| eval last_seen_age_sec=now()-last_seen
| table check_host leader_id version revision raft_term last_seen_age_sec
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">5</option>
        <option name="drilldown">none</option>
      </table>
    </panel>

    <panel>
      <table>
        <title>Node Reporting Freshness</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(_time) as last_seen latest(health) as health latest(severity) as severity by check_host
| eval age_sec=now()-last_seen
| eval state=case(age_sec<=600,"healthy reporting", age_sec<=1800,"late", true(),"stale / not reporting recently")
| table check_host last_seen age_sec health severity state
| sort check_host
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <table>
        <title>Latest Per-Node Status</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(_time) as last_seen
        latest(status) as status
        latest(severity) as severity
        latest(check_ip) as check_ip
        latest(endpoint) as endpoint
        latest(health) as health
        latest(is_leader) as is_leader
        latest(version) as version
        latest(revision) as revision
        latest(db_size_in_use_pct) as db_used_pct
        latest(raft_term) as raft_term
        latest(raft_index) as raft_index
        latest(raft_applied_index) as raft_applied_index
        latest(has_alarm) as has_alarm
        latest(alarms) as alarms
        latest(latest_backup_age_sec) as backup_age_sec
        latest(status_errors) as status_errors
        latest(notable) as notable
        by check_host
| eval last_seen_age_sec=now()-last_seen
| eval reporting_state=case(last_seen_age_sec<=600,"current", last_seen_age_sec<=1800,"late", true(),"stale")
| eval backup_age_hr=round(backup_age_sec/3600,2)
| table check_host reporting_state last_seen_age_sec status severity check_ip endpoint health is_leader version revision db_used_pct raft_term raft_index raft_applied_index has_alarm alarms backup_age_hr status_errors notable
| sort check_host
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">row</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <table>
        <title>Revision / Raft Lag by Node</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(revision) as revision
        latest(raft_index) as raft_index
        latest(raft_applied_index) as raft_applied_index
        latest(raft_term) as raft_term
        latest(health) as health
        latest(severity) as severity
        by check_host
| eventstats max(revision) as max_revision max(raft_index) as max_raft_index max(raft_applied_index) as max_raft_applied_index
| eval revision_lag=max_revision-revision
| eval raft_index_lag=max_raft_index-raft_index
| eval raft_applied_lag=max_raft_applied_index-raft_applied_index
| table check_host health severity revision revision_lag raft_index raft_index_lag raft_applied_index raft_applied_lag raft_term
| sort - revision_lag - raft_index_lag
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">none</option>
      </table>
    </panel>

    <panel>
      <table>
        <title>Backup Freshness by Node</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| stats latest(_time) as last_seen
        latest(latest_backup_file) as latest_backup_file
        latest(latest_backup_epoch) as latest_backup_epoch
        latest(latest_backup_age_sec) as latest_backup_age_sec
        latest(latest_backup_size_bytes) as latest_backup_size_bytes
        latest(severity) as severity
        by check_host
| eval backup_age_hr=round(latest_backup_age_sec/3600,2)
| eval backup_state=case(isnull(latest_backup_age_sec),"missing", latest_backup_age_sec>86400,"stale", true(),"ok")
| table check_host backup_state backup_age_hr latest_backup_size_bytes latest_backup_file severity
| sort check_host
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">20</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <chart>
        <title>DB Size In Use % Over Time</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| timechart span=5m latest(db_size_in_use_pct) by check_host limit=0
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.axisY.minimumNumber">0</option>
        <option name="charting.axisY.maximumNumber">100</option>
        <option name="drilldown">none</option>
      </chart>
    </panel>

    <panel>
      <chart>
        <title>Backup Age (Hours) Over Time</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| eval backup_age_hr=latest_backup_age_sec/3600
| timechart span=5m latest(backup_age_hr) by check_host limit=0
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="drilldown">none</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <chart>
        <title>Revision Trend by Node</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| timechart span=5m latest(revision) by check_host limit=0
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="drilldown">none</option>
      </chart>
    </panel>

    <panel>
      <chart>
        <title>Issue Event Trend</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| eval has_status_errors=if(mvcount(status_errors{})>0 OR mvcount(status_errors)>0,1,0)
| eval is_issue=if(status!="ok" OR health=false OR has_alarm=true OR latest_backup_age_sec>86400 OR db_size_in_use_pct>=85 OR has_status_errors=1,1,0)
| timechart span=5m sum(is_issue) as issue_events
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="drilldown">none</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <table>
        <title>Recent Issue Events</title>
        <search>
          <query><![CDATA[
index=operational_logs_30 sourcetype=etcd:node:health:json
| where "$node_tok$"="*" OR check_host="$node_tok$"
| eval has_status_errors=if(mvcount(status_errors{})>0 OR mvcount(status_errors)>0,1,0)
| where status!="ok" OR health=false OR has_alarm=true OR latest_backup_age_sec>86400 OR db_size_in_use_pct>=85 OR has_status_errors=1
| eval backup_age_hr=round(latest_backup_age_sec/3600,2)
| table _time check_host check_ip endpoint severity status health is_leader version revision db_size_in_use_pct has_alarm alarms backup_age_hr status_errors notable
| sort - _time
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">50</option>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
</form>
