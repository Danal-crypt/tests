#!/bin/bash

echo "============================================"
echo "Splunk User Check"
echo "============================================"
echo

read -r -p "Enter user to check: " USER_ID
echo

for SITE in fdic.splunkcloudgc.com es.fdic.splunkcloudgc.com idm.fdic.splunkcloudgc.com qmulos.fdic.splunkcloudgc.com
do
    ADMINPWD=$(/opt/CARKaim/sdk/clipasswordsdk GetPassword \
        -p AppDescs.AppID=SPLUNK-PROD \
        -p "Query=safe=APP_SPLUNK-SPLUNK-P;folder=Root;object=${SITE}-splunkmaintenancep;" \
        -o Password)

    if [ -z "$ADMINPWD" ]; then
        echo "$SITE | ERROR: Failed to retrieve admin password"
        continue
    fi

    USER_RESPONSE=$(curl -sk -G \
        -u "splunkmaintenancep:$ADMINPWD" \
        "https://$SITE:8089/services/authentication/users" \
        --data-urlencode "search=name=\"$USER_ID\"" \
        -d "count=1" \
        -d "output_mode=json")

    USER_TOTAL=$(echo "$USER_RESPONSE" | grep -o '"total":[[:space:]]*[0-9]*' | head -1 | awk -F: '{gsub(/ /,"",$2); print $2}')
    [ -z "$USER_TOTAL" ] && USER_TOTAL=0

    KO_RESPONSE=$(curl -sk -G \
        -u "splunkmaintenancep:$ADMINPWD" \
        "https://$SITE:8089/servicesNS/-/-/admin/directory" \
        --data-urlencode "search=eai:acl.owner=\"$USER_ID\"" \
        -d "count=1" \
        -d "output_mode=json")

    KO_TOTAL=$(echo "$KO_RESPONSE" | grep -o '"total":[[:space:]]*[0-9]*' | head -1 | awk -F: '{gsub(/ /,"",$2); print $2}')
    [ -z "$KO_TOTAL" ] && KO_TOTAL=0

    if [ "$USER_TOTAL" -gt 0 ]; then
        echo "$SITE | User Found | KOs: $KO_TOTAL"
    else
        echo "$SITE | User Not Found | KOs: $KO_TOTAL"
    fi
done
