#!/bin/bash
set -uo pipefail

# Resolve SPLUNK_HOME from .../etc/apps/<app>/bin/
SPLUNK_HOME="$(cd "$(dirname "$0")/../../../.." && pwd)"
STATE_DIR="$SPLUNK_HOME/var/run/TA_journald_stdout"
CURSOR_FILE="$STATE_DIR/last_cursor"
LOCK_FILE="$STATE_DIR/run.lock"
TMP_CURSOR="$STATE_DIR/.cursor.tmp"

# Keep first run intentionally small so we don't backfill a ton of data.
INITIAL_LOOKBACK="-90 seconds"

mkdir -p "$STATE_DIR" || exit 1

# Prevent overlap if a prior run is still active.
exec 9>"$LOCK_FILE" || exit 1
flock -n 9 || exit 0

BASE_CMD=(env -u LD_LIBRARY_PATH /usr/bin/journalctl --no-pager -o json)

if [[ -s "$CURSOR_FILE" ]]; then
    START_CURSOR="$(cat "$CURSOR_FILE")"
    CMD=("${BASE_CMD[@]}" --after-cursor="$START_CURSOR")
else
    CMD=("${BASE_CMD[@]}" --since "$INITIAL_LOOKBACK")
fi

# Stream events directly to stdout.
# Save the last seen __CURSOR as we go, so disk usage stays tiny.
"${CMD[@]}" 2>&1 | while IFS= read -r line; do
    # If journalctl errors, send the error to stderr so it lands in splunkd logs.
    if [[ "$line" != \{* ]]; then
        printf '%s\n' "$line" >&2
        continue
    fi

    # Emit the event to Splunk.
    printf '%s\n' "$line"

    # Extract __CURSOR from the JSON line.
    cursor="$(printf '%s\n' "$line" | sed -n 's/.*"__CURSOR":"\([^"]*\)".*/\1/p')"
    if [[ -n "$cursor" ]]; then
        printf '%s\n' "$cursor" > "$TMP_CURSOR" && mv "$TMP_CURSOR" "$CURSOR_FILE"
    fi
done

exit 0
