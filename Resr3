<YOUR EXISTING MISSING RESULTS SEARCH HERE>
| eval ageHrs=round(ageSec/3600,1)
| eval sev=case(
    ageSec >= 7*86400, "CRITICAL (7d+)",
    ageSec >= 3*86400, "HIGH (3-7d)",
    ageSec >= 86400,   "MED (1-3d)",
    true(),            "LOW (<1d)"
)
| stats
    count as MissingRows
    dc(host) as AffectedHosts
    max(ageSec) as WorstAgeSec
    max(lastTime) as MostRecentLastTime
    values(host) as HostList
    values(todayCount) as todayCount
    values(yesterdayCount) as yesterdayCount
    values(weekCount) as weekCount
  by index sourcetype sev
| eval WorstAgeHrs=round(WorstAgeSec/3600,1)
| eval MostRecentLastSeen=strftime(MostRecentLastTime,"%F %T")
| eval HostsPreview=mvjoin(mvindex(HostList,0,9), ", ")
| eval HostsPreview=if(AffectedHosts>10, HostsPreview . " …", HostsPreview)
| eval Notes=""
| table sev index sourcetype AffectedHosts WorstAgeHrs MostRecentLastSeen todayCount yesterdayCount weekCount HostsPreview Notes
| sort 0 sev -WorstAgeHrs
