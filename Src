index=_internal sourcetype=splunk_web_access status=200 earliest=-7d@d latest=now
user!="-" user!="splunk-system-user"
| eval User=lower(replace(user,"-.*$",""))
| where isnotnull(User) AND User!=""

| eval idle_timeout_sec=900

| sort 0 User - _time
| streamstats current=f window=1 last(_time) as next_time by User
| eval span_sec=next_time-_time
| where span_sec>0 AND span_sec<=idle_timeout_sec

| eval start=_time
| eval stop=next_time
| eval minute=mvrange(floor(start/60)*60, ceil(stop/60)*60, 60)
| mvexpand minute

| eval overlap_start=if(start>minute,start,minute)
| eval overlap_end=if(stop<minute+60,stop,minute+60)
| eval active_sec=overlap_end-overlap_start
| where active_sec>0

| eval _time=minute
| bin _time span=1h

| stats sum(active_sec) as active_sec by User _time
| eval Hour=strftime(_time,"%Y-%m-%d %H:00")
| eval Day=strftime(_time,"%Y-%m-%d")
| eval Hourly_Minutes=round(active_sec/60,2)

| eventstats sum(active_sec) as daily_active_sec by User Day
| eval Daily_Minutes=round(daily_active_sec/60,2)
| eval Daily_Access_Time=tostring(round(daily_active_sec), "duration")

| table Day Hour User Hourly_Minutes Daily_Minutes Daily_Access_Time
| sort 0 Day Hour User
