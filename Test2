#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="/opt/splunk"

EXCLUDE_DIRS=(
  "/opt/splunk/etc/default"
  "/opt/splunk/var"
)

HOSTNAME="$(hostname -f 2>/dev/null || hostname)"
TS="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

# Build prune expression for find
prune_expr=()
for d in "${EXCLUDE_DIRS[@]}"; do
  prune_expr+=( -path "$d" -o )
done
unset 'prune_expr[${#prune_expr[@]}-1]'

emit_json() {
  local file="$1" readable="$2" error="$3"
  local size_bytes="$4" mtime_raw="$5" perms="$6" uid="$7" gid="$8" owner="$9" group="${10}" sha256="${11}"

  python3 -c '
import json, sys

path = sys.argv[1]
host = sys.argv[2]
ts = sys.argv[3]
readable = sys.argv[4].lower() == "true"
error = sys.argv[5] or None

size_bytes = sys.argv[6]
mtime = sys.argv[7] or None
perms = sys.argv[8] or None
uid = sys.argv[9]
gid = sys.argv[10]
owner = sys.argv[11] or None
group = sys.argv[12] or None
sha256 = sys.argv[13] or None

def to_int_or_none(s):
    try:
        return int(s)
    except Exception:
        return None

event = {
  "path": path,
  "host": host,
  "ts": ts,
  "readable": readable,
  "error": error,
  "size_bytes": to_int_or_none(size_bytes),
  "mtime": mtime,
  "perms": perms,
  "uid": to_int_or_none(uid),
  "gid": to_int_or_none(gid),
  "owner": owner,
  "group": group,
  "sha256": sha256,
}

# stdin is the file contents (because we are NOT using a heredoc)
if readable:
    event["conf_contents"] = sys.stdin.read()

print(json.dumps(event, ensure_ascii=False, separators=(",", ":")))
' "$file" "$HOSTNAME" "$TS" "$readable" "$error" \
    "$size_bytes" "$mtime_raw" "$perms" "$uid" "$gid" "$owner" "$group" "$sha256"
}

find "$BASE_DIR" \
  \( "${prune_expr[@]}" \) -prune -o \
  -type f -name "*.conf" -print0 2>/dev/null \
  | sort -z \
  | while IFS= read -r -d '' file; do

      # Metadata via normal commands
      size_bytes="$(stat -c '%s' -- "$file" 2>/dev/null || echo "")"
      mtime_raw="$(stat -c '%y' -- "$file" 2>/dev/null || echo "")"
      perms="$(stat -c '%a' -- "$file" 2>/dev/null || echo "")"
      uid="$(stat -c '%u' -- "$file" 2>/dev/null || echo "")"
      gid="$(stat -c '%g' -- "$file" 2>/dev/null || echo "")"
      owner="$(stat -c '%U' -- "$file" 2>/dev/null || echo "")"
      group="$(stat -c '%G' -- "$file" 2>/dev/null || echo "")"

      if [[ ! -r "$file" ]]; then
        # No contents; pass empty stdin
        emit_json "$file" "false" "permission_denied" \
          "$size_bytes" "$mtime_raw" "$perms" "$uid" "$gid" "$owner" "$group" "" < /dev/null
        continue
      fi

      sha256="$(sha256sum -- "$file" 2>/dev/null | awk "{print \$1}" || echo "")"

      # Pipe the actual file contents into python stdin (NUL stripped)
      tr -d '\000' < "$file" | emit_json "$file" "true" "" \
        "$size_bytes" "$mtime_raw" "$perms" "$uid" "$gid" "$owner" "$group" "$sha256"
    done
