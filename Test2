#!/usr/bin/env bash
set -euo pipefail

BASE_DIR="/opt/splunk"

EXCLUDE_DIRS=(
  "/opt/splunk/etc/default"
  "/opt/splunk/var"
)

HOSTNAME="$(hostname -f 2>/dev/null || hostname)"
TS="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

# Build prune expression
prune_expr=()
for d in "${EXCLUDE_DIRS[@]}"; do
  prune_expr+=( -path "$d" -o )
done
unset 'prune_expr[${#prune_expr[@]}-1]'

emit_json() {
  local file="$1" readable="$2" error="$3"
  local size_bytes="$4" mtime_raw="$5" perms="$6" uid="$7" gid="$8" owner="$9" group="${10}" sha256="${11}"

  python3 - "$file" "$HOSTNAME" "$TS" "$readable
