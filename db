| inputlookup ddhc_findings.csv
| eval status=coalesce(status,"new")
| search severity="$tok_severity$" category="$tok_category$" index="$tok_index_filter$" owner="$tok_owner_filter$"
| search status!="resolved" status!="false_positive"
| eval severity_rank=case(severity="critical",1,severity="high",2,severity="medium",3,severity="low",4,true(),5)
| eval object=case(
    isnotnull(source) AND source!="*" AND source!="", index." / ".sourcetype." / ".host." / ".source,
    isnotnull(host) AND host!="*" AND host!="", index." / ".sourcetype." / ".host,
    isnotnull(sourcetype) AND sourcetype!="*" AND sourcetype!="", index." / ".sourcetype,
    isnotnull(index) AND index!="", index,
    true(), coalesce(component,category)
)
| eval pct_change=if(isnum(pct_change),round(pct_change,2),pct_change)
| eval zscore=if(isnum(zscore),round(zscore,2),zscore)
| table severity category anomaly_type object finding actual_value baseline_value pct_change zscore recovered likely_cause recommended_action owner status first_seen last_seen finding_id index sourcetype host source
| sort severity_rank category object
          ]]></query>
          <earliest>$tok_time.earliest$</earliest>
          <latest>$tok_time.latest$</latest>
