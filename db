| eval baseline_dow=strftime(_time,"%A"), target_dow=strftime(relative_time(now(),"-1d@d"),"%A") \
| where baseline_dow=target_dow \
| stats count as baseline_days avg(count) as avg_count median(count) as median_count stdev(count) as stdev_count perc25(count) as p25 perc75(count) as p75 min(count) as min_count max(count) as max_count by index sourcetype \
| eval updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| outputlookup ddhc_sourcetype_daily_baseline.csv


[DDHC 02 - Maintain Host Source Last Seen]
disabled = 0
description = Maintains exact-source and wildcard-source last-seen records for host/index/sourcetype/source monitoring.
cron_schedule = */15 * * * *
dispatch.earliest_time = -14d
dispatch.latest_time = now
search = | tstats summariesonly=false latest(_time) as last_seen count as event_count_14d where index=* earliest=-14d latest=now by index sourcetype host source \
| append [ | tstats summariesonly=false latest(_time) as last_seen count as event_count_14d where index=* earliest=-14d latest=now by index sourcetype host | eval source="*" ] \
| eval event_count_24h=0 \
| append [ | tstats summariesonly=false count as event_count_24h where index=* earliest=-24h latest=now by index sourcetype host source | eval last_seen=null(), event_count_14d=0 ] \
| append [ | tstats summariesonly=false count as event_count_24h where index=* earliest=-24h latest=now by index sourcetype host | eval source="*", last_seen=null(), event_count_14d=0 ] \
| stats max(last_seen) as last_seen sum(event_count_14d) as event_count_14d sum(event_count_24h) as event_count_24h by index sourcetype host source \
| eval last_seen_readable=strftime(last_seen,"%F %T"), minutes_since_seen=round((now()-last_seen)/60,1), updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| outputlookup ddhc_host_source_last_seen.csv


[DDHC 03 - Build Today Projection]
disabled = 0
description = Projects today's index/sourcetype volume to help determine whether yesterday's anomaly recovered.
cron_schedule = 5 * * * *
dispatch.earliest_time = @d
dispatch.latest_time = now
search = | tstats summariesonly=false count as today_count where index=* earliest=@d latest=now by index sourcetype \
| eval hours_elapsed=round((now()-relative_time(now(),"@d"))/3600,2) \
| eval projected_today=round((today_count/hours_elapsed)*24,0) \
| eval updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| outputlookup ddhc_today_projection.csv


[DDHC 04 - Detect Index Volume Anomalies]
disabled = 0
description = Detects index-level drops/spikes using same-day-of-week baseline, IQR, z-score, and today recovery projection.
cron_schedule = 30 1 * * *
dispatch.earliest_time = -1d@d
dispatch.latest_time = @d
search = | tstats summariesonly=false count as yesterday_count where index=* earliest=-1d@d latest=@d by index \
| lookup ddhc_index_daily_baseline.csv index OUTPUT baseline_days avg_count median_count stdev_count p25 p75 min_count max_count \
| eval stdev_count=if(isnull(stdev_count) OR stdev_count=0,1,stdev_count), median_count=coalesce(median_count,0), avg_count=coalesce(avg_count,0) \
| eval diff=yesterday_count-median_count, pct_change=round((diff/median_count)*100,2), zscore=round((yesterday_count-avg_count)/stdev_count,2), iqr=p75-p25, lower_bound=p25-(1.5*iqr), upper_bound=p75+(1.5*iqr) \
| eval anomaly_type=case(yesterday_count=0 AND median_count>1000,"drop",yesterday_count<lower_bound AND pct_change<-50,"drop",yesterday_count>upper_bound AND pct_change>100,"spike",abs(zscore)>=3 AND yesterday_count>1000,"outlier",true(),"normal") \
| where anomaly_type!="normal" \
| lookup ddhc_today_projection.csv index OUTPUT projected_today as projected_today_index \
| eval recovered=case(anomaly_type="drop" AND projected_today_index>=median_count*0.75,1,anomaly_type="spike" AND projected_today_index<=median_count*1.5,1,true(),0) \
| eval severity=case(yesterday_count=0 AND median_count>10000,"critical",anomaly_type="drop" AND pct_change<-75,"critical",anomaly_type="drop","high",anomaly_type="spike" AND pct_change>300,"high",anomaly_type="spike","medium",true(),"low") \
| eval category="index_volume", sourcetype="*", host="*", source="*", actual_value=yesterday_count, baseline_value=median_count \
| eval finding="Index volume ".anomaly_type.": yesterday=".yesterday_count.", median=".median_count.", pct_change=".pct_change."%" \
| eval likely_cause=case(anomaly_type="drop" AND recovered=0,"Index volume is still tracking below baseline today.",anomaly_type="drop" AND recovered=1,"Index volume dropped yesterday but appears recovered today.",anomaly_type="spike" AND recovered=0,"Index volume is still tracking above baseline today.",anomaly_type="spike" AND recovered=1,"Index volume spiked yesterday but appears recovered today.",true(),"Index-level statistical outlier detected.") \
| eval recommended_action="Click the finding, review sourcetype/host/source contributors, then check correlated _internal and Cribl panels." \
| eval first_seen=strftime(relative_time(now(),"-1d@d"),"%F %T"), last_seen=strftime(relative_time(now(),"@d"),"%F %T"), updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| eval finding_id=md5(category."|".index."|".sourcetype."|".anomaly_type."|".first_seen) \
| table finding_id severity category anomaly_type index sourcetype host source finding actual_value baseline_value pct_change zscore lower_bound upper_bound recovered likely_cause recommended_action first_seen last_seen updated_epoch updated \
| outputlookup ddhc_index_anomalies.csv


