      <table>
        <search>
          <query><![CDATA[
index=_internal source=*license_usage.log type=Usage earliest=-31d@d latest=@d
| eval day=strftime(_time,"%F")
| stats sum(b) as bytes by day idx st
| eval gb=bytes/1024/1024/1024
| eval yesterday_day=strftime(relative_time(now(),"-1d@d"),"%F")
| eval is_yesterday=if(day=yesterday_day,1,0)
| eventstats values(eval(if(is_yesterday=1,gb,null()))) as yesterday_gb by idx st
| where is_yesterday=0
| stats median(gb) as median_gb avg(gb) as avg_gb stdev(gb) as stdev_gb values(yesterday_gb) as yesterday_gb by idx st
| eval pct_change=round(((yesterday_gb-median_gb)/median_gb)*100,2)
| where isnotnull(yesterday_gb) AND abs(pct_change)>50 AND yesterday_gb>1
| rename idx as index st as sourcetype
| table index sourcetype yesterday_gb median_gb pct_change
| sort -abs(pct_change)
          ]]></query>
        </search>
        <option name="count">25</option>
