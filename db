[DDHC 06 - Detect Missing Expected Sources]
disabled = 0
description = Compares ddhc_expected_data_sources.csv against last-seen records.
cron_schedule = */15 * * * *
dispatch.earliest_time = -15m
dispatch.latest_time = now
search = | inputlookup ddhc_expected_data_sources.csv \
| eval source=coalesce(source,"*"), expected_frequency_minutes=coalesce(expected_frequency_minutes,60), criticality=lower(coalesce(criticality,"medium")), owner=coalesce(owner,"unknown"), environment=coalesce(environment,"unknown") \
| lookup ddhc_host_source_last_seen.csv index sourcetype host source OUTPUT last_seen_readable as last_seen minutes_since_seen event_count_24h \
| eval status=case(isnull(last_seen),"never_seen",minutes_since_seen>expected_frequency_minutes*4,"late",event_count_24h=0,"no_events_24h",true(),"healthy") \
| where status!="healthy" \
| eval severity=case(criticality="critical","critical",criticality="high","high",status="never_seen","high",true(),"medium") \
| eval category="missing_expected_source", anomaly_type="drop", actual_value=event_count_24h, baseline_value=expected_frequency_minutes, pct_change=null(), zscore=null(), recovered=0 \
| eval finding="Expected data source status=".status."; minutes_since_seen=".coalesce(minutes_since_seen,"null")."; expected_frequency_minutes=".expected_frequency_minutes \
| eval likely_cause=case(status="never_seen","Expected data source has not been observed in the last-seen lookup.",status="late","Expected data source is late based on configured expected_frequency_minutes.",status="no_events_24h","Expected data source has no events in the last 24 hours.",true(),"Expected data source is unhealthy.") \
| eval recommended_action="Check source application, forwarder service, outputs.conf, deployment status, network path, and upstream collector/Cribl route." \
| eval first_seen=strftime(now(),"%F %T"), last_seen=coalesce(last_seen,"never_seen"), updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| eval finding_id=md5(category."|".index."|".sourcetype."|".host."|".source) \
| table finding_id severity category anomaly_type index sourcetype host source owner criticality environment status finding actual_value baseline_value pct_change zscore recovered likely_cause recommended_action first_seen last_seen minutes_since_seen event_count_24h expected_frequency_minutes updated_epoch updated \
| outputlookup ddhc_missing_expected_sources.csv


[DDHC 07 - Detect New Data Combinations]
disabled = 0
description = Detects new index/sourcetype/host/source combinations first seen in the last 24 hours.
cron_schedule = 15 * * * *
dispatch.earliest_time = -31d
dispatch.latest_time = now
search = | tstats summariesonly=false earliest(_time) as first_seen_epoch latest(_time) as last_seen_epoch count where index=* earliest=-31d latest=now by index sourcetype host source \
| where first_seen_epoch>=relative_time(now(),"-24h") \
| eval severity=case(count>1000000,"high",count>100000,"medium",true(),"informational") \
| eval category="new_data", anomaly_type="new", actual_value=count, baseline_value=0, pct_change=null(), zscore=null(), recovered=0 \
| eval first_seen=strftime(first_seen_epoch,"%F %T"), last_seen=strftime(last_seen_epoch,"%F %T") \
| eval finding="New index/sourcetype/host/source combination observed with count=".count \
| eval likely_cause="Newly onboarded data, changed sourcetype/source, misrouting, or previously silent source returned." \
| eval recommended_action="Verify this is expected onboarding or an approved data routing/sourcetype change." \
| eval owner="unknown", updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| eval finding_id=md5(category."|".index."|".sourcetype."|".host."|".source."|".first_seen) \
| table finding_id severity category anomaly_type index sourcetype host source finding actual_value baseline_value pct_change zscore recovered likely_cause recommended_action owner first_seen last_seen updated_epoch updated count \
| outputlookup ddhc_new_data.csv


[DDHC 08 - Summarize Splunk Internal Errors]
disabled = 0
description = Summarizes Splunk internal errors and classifies them by common operational categories.
cron_schedule = */15 * * * *
dispatch.earliest_time = -24h
dispatch.latest_time = now
search = index=_internal earliest=-24h latest=now (error OR warn OR warning OR failed OR failure OR timeout OR blocked OR refused OR reset OR SSL OR certificate OR handshake OR queue OR license) \
| eval raw_l=lower(_raw) \
| eval error_category=case(match(raw_l,"ssl|certificate|handshake|tls"),"ssl_tls_certificate",match(raw_l,"tcpoutputproc|autoloadbalancedconnectionstrategy|connection refused|connection reset|cooked connection"),"forwarder_output_connection",match(raw_l,"tcpinputproc|tcpinputconfig"),"receiver_tcp_input",match(raw_l,"queue|blocked"),"queue_blockage",match(raw_l,"license"),"license",match(raw_l,"truncat|linebreaking|dateparser|timestamp|parse"),"parsing_timestamp",match(raw_l,"scheduler|skipped|savedsearch"),"scheduler",true(),"general_internal") \
| eval severity=case(error_category="ssl_tls_certificate","high",error_category="queue_blockage","high",error_category="license","high",error_category="forwarder_output_connection","medium",error_category="receiver_tcp_input","medium",true(),"low") \
| stats count latest(_raw) as latest_error latest(_time) as latest_time_epoch by severity error_category host component log_level \
| eval latest_time=strftime(latest_time_epoch,"%F %T") \
| eval category="internal_error", anomaly_type="error", index="*", sourcetype="*", source="*", actual_value=count, baseline_value=0, pct_change=null(), zscore=null(), recovered=0 \
| eval finding="Splunk internal ".error_category." errors observed on ".host."; count=".count \
| eval likely_cause=case(error_category="ssl_tls_certificate","TLS/certificate/trust chain or name validation problem.",error_category="queue_blockage","Possible indexing/forwarding/processing backpressure.",error_category="license","License pool/usage warning or violation.",error_category="forwarder_output_connection","Forwarder cannot reliably reach receiver/destination.",error_category="receiver_tcp_input","Receiver/TCP input issue on Splunk tier.",error_category="parsing_timestamp","Parsing, line-breaking, timestamping, or truncation issue.",true(),"Internal Splunk warning/error requires review.") \
| eval recommended_action="Open latest_error, identify affected tier, then correlate to data drops/spikes and host/source last-seen panels." \
| eval first_seen=strftime(relative_time(now(),"-24h"),"%F %T"), last_seen=latest_time, updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| eval finding_id=md5(category."|".error_category."|".host."|".component."|".log_level) \
| table finding_id severity category anomaly_type index sourcetype host source component log_level error_category finding actual_value baseline_value pct_change zscore recovered likely_cause recommended_action latest_error first_seen last_seen latest_time updated_epoch updated count \
| outputlookup ddhc_internal_error_summary.csv


[DDHC 09 - Detect Data Quality Issues]
disabled = 0
description = Detects future-dated events, late-arriving data, suspicious sourcetypes, and common parsing/timestamp issues.
cron_schedule = 25 * * * *
dispatch.earliest_time = -24h
dispatch.latest_time = now
search = | tstats summariesonly=false count where index=* earliest=-24h latest=+7d by index sourcetype host _time span=1h \
| where _time>now()+300 \
| stats sum(count) as count min(_time) as min_bad_time max(_time) as max_bad_time by index sourcetype host \
| eval quality_category="future_dated_events", metric_value=strftime(max_bad_time,"%F %T"), severity=case(count>100000,"high",count>10000,"medium",true(),"low") \
| append [ search index=* earliest=-24h latest=now | eval lag_seconds=_indextime-_time | where lag_seconds>3600 | stats count avg(lag_seconds) as avg_lag max(lag_seconds) as max_lag by index sourcetype host | eval quality_category="late_arriving_data", metric_value=round(max_lag/3600,2)." hours max lag", severity=case(max_lag>86400,"high",max_lag>21600,"medium",true(),"low") ] \
| append [ | tstats summariesonly=false count where index=* earliest=-24h latest=now by index sourcetype host | where sourcetype IN ("too_small","stash","unknown","syslog","csv","json","_json","default") | eval quality_category="suspicious_sourcetype", metric_value=sourcetype, severity=case(count>100000,"medium",true(),"low") ] \
| eval category="data_quality", anomaly_type="quality", source="*", actual_value=count, baseline_value=0, pct_change=null(), zscore=null(), recovered=0 \
| eval finding=case(quality_category="future_dated_events","Events have _time in the future.",quality_category="late_arriving_data","Events are arriving more than one hour late.",quality_category="suspicious_sourcetype","Potential generic/default/bad sourcetype observed.",true(),"Data quality issue observed.") \
| eval likely_cause=case(quality_category="future_dated_events","Source clock, timezone, timestamp extraction, or props issue.",quality_category="late_arriving_data","Backlog, replay, delayed source delivery, queueing, or timestamp issue.",quality_category="suspicious_sourcetype","Misrouted data, missing props/transforms, source type override issue, or default assignment.",true(),"Data quality issue requires review.") \
| eval recommended_action="Review raw events, source clock/timestamp format, props/transforms, Cribl routing, and ingestion path." \
| eval owner="unknown", first_seen=strftime(relative_time(now(),"-24h"),"%F %T"), last_seen=strftime(now(),"%F %T"), updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| eval finding_id=md5(category."|".quality_category."|".index."|".sourcetype."|".host) \
| table finding_id severity category anomaly_type quality_category index sourcetype host source finding actual_value baseline_value pct_change zscore metric_value recovered likely_cause recommended_action owner first_seen last_seen updated_epoch updated count \
| outputlookup ddhc_data_quality.csv


[DDHC 10 - Summarize Cribl Health Optional]
disabled = 0
description = Optional Cribl health summary. Adjust field names to your criblmetrics schema if needed.
cron_schedule = */15 * * * *
dispatch.earliest_time = -24h
dispatch.latest_time = now
search = index=criblmetrics earliest=-24h latest=now \
| eval cribl_category=case(match(lower(_raw),"error|failed|exception|refused|reset|timeout|unhealthy"),"cribl_error",isnotnull(bytes_in) OR isnotnull(bytes_out),"cribl_volume",true(),"cribl_metric") \
| eval route=coalesce(route,Route,cribl_route,"unknown"), pipeline=coalesce(pipeline,Pipeline,cribl_pipeline,"unknown"), destination=coalesce(dest,destination,output,cribl_dest,"unknown") \
| stats count sum(bytes_in) as bytes_in sum(bytes_out) as bytes_out latest(_raw) as latest_error latest(_time) as latest_time_epoch by cribl_category host route pipeline destination \
| eval bytes_in=coalesce(bytes_in,0), bytes_out=coalesce(bytes_out,0), drop_pct=if(bytes_in>0,round(((bytes_in-bytes_out)/bytes_in)*100,2),null()) \
| where cribl_category="cribl_error" OR drop_pct>20 \
| eval severity=case(cribl_category="cribl_error" AND count>100,"high",drop_pct>80,"critical",drop_pct>50,"high",drop_pct>20,"medium",true(),"low") \
| eval category="cribl_health", anomaly_type=case(cribl_category="cribl_error","error",true(),"drop"), index="*", sourcetype="*", source="*", actual_value=coalesce(bytes_out,count), baseline_value=bytes_in, pct_change=drop_pct, zscore=null(), recovered=0 \
| eval finding=case(cribl_category="cribl_error","Cribl errors observed. count=".count,"Cribl bytes_out appears lower than bytes_in. drop_pct=".drop_pct."%",true(),"Cribl health issue observed.") \
| eval likely_cause="Cribl route, pipeline, destination, network, TLS, or output backpressure issue." \
| eval recommended_action="Check Cribl worker/group health, route, pipeline, destination config, TLS status, and destination availability." \
| eval latest_time=strftime(latest_time_epoch,"%F %T"), first_seen=strftime(relative_time(now(),"-24h"),"%F %T"), last_seen=latest_time, owner="unknown", updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| eval finding_id=md5(category."|".cribl_category."|".host."|".route."|".pipeline."|".destination) \
| table finding_id severity category anomaly_type cribl_category index sourcetype host source route pipeline destination finding actual_value baseline_value pct_change zscore recovered likely_cause recommended_action latest_error first_seen last_seen latest_time updated_epoch updated count bytes_in bytes_out drop_pct \
| outputlookup ddhc_cribl_health_summary.csv


[DDHC 11 - Build Normalized Findings]
disabled = 0
description = Combines all DDHC lookup outputs into a single normalized findings queue used by the dashboard.
cron_schedule = */15 * * * *
dispatch.earliest_time = -15m
dispatch.latest_time = now
search = | inputlookup ddhc_index_anomalies.csv \
| append [ | inputlookup ddhc_sourcetype_anomalies.csv ] \
| append [ | inputlookup ddhc_missing_expected_sources.csv ] \
| append [ | inputlookup ddhc_new_data.csv ] \
| append [ | inputlookup ddhc_internal_error_summary.csv ] \
| append [ | inputlookup ddhc_data_quality.csv ] \
| append [ | inputlookup ddhc_cribl_health_summary.csv ] \
| eval finding_id=coalesce(finding_id,md5(category."|".index."|".sourcetype."|".host."|".source."|".finding)) \
| eval owner=coalesce(owner,"unknown"), status="new" \
| lookup ddhc_finding_status.csv finding_id OUTPUT status as analyst_status analyst comment last_updated \
| eval status=coalesce(analyst_status,status) \
| eval severity=lower(coalesce(severity,"informational")), category=coalesce(category,"uncategorized"), anomaly_type=coalesce(anomaly_type,"unknown") \
| eval index=coalesce(index,"*"), sourcetype=coalesce(sourcetype,"*"), host=coalesce(host,"*"), source=coalesce(source,"*") \
| eval evidence=case(category="internal_error",latest_error,category="cribl_health",latest_error,true(),coalesce(evidence,"")) \
| eval updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| table finding_id severity category anomaly_type index sourcetype host source component log_level error_category quality_category cribl_category route pipeline destination finding actual_value baseline_value pct_change zscore recovered likely_cause recommended_action evidence owner status analyst comment first_seen last_seen updated_epoch updated \
| outputlookup ddhc_findings.csv

