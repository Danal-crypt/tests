[DDHC ML 02 - Score Index Daily Density Anomalies]
disabled = 0
description = Applies MLTK daily index volume model to yesterday and writes ddhc_ml_index_anomalies.csv.
cron_schedule = 15 2 * * *
dispatch.earliest_time = -1d@d
dispatch.latest_time = @d
search = | tstats summariesonly=false count as event_count where index=* earliest=-1d@d latest=@d by index \
| eval _time=relative_time(now(),"-1d@d") \
| eval day_of_week=strftime(_time,"%A") \
| apply ddhc_index_daily_density \
| rename event_count as yesterday_count \
| eval is_outlier=coalesce(IsOutlier,event_count_isOutlier,isOutlier,is_outlier,'IsOutlier(event_count)',0) \
| eval ml_score=coalesce(BoundaryRanges,ProbabilityDensity,probability_density,score,log_pdf,null()) \
| where is_outlier=1 \
| lookup ddhc_index_daily_baseline.csv index OUTPUT median_count avg_count stdev_count \
| lookup ddhc_today_projection.csv index OUTPUT projected_today as projected_today_index \
| eval median_count=coalesce(median_count,0) \
| eval pct_change=if(median_count>0,round(((yesterday_count-median_count)/median_count)*100,2),null()) \
| eval anomaly_type=case(yesterday_count<median_count,"drop",yesterday_count>median_count,"spike",true(),"outlier") \
| eval recovered=case(anomaly_type="drop" AND projected_today_index>=median_count*0.75,1,anomaly_type="spike" AND projected_today_index<=median_count*1.5,1,true(),0) \
| eval severity=case(anomaly_type="drop" AND pct_change<-75,"critical",anomaly_type="drop","high",anomaly_type="spike" AND pct_change>300,"high",true(),"medium") \
| eval category="ml_index_volume", sourcetype="*", host="*", source="*", actual_value=yesterday_count, baseline_value=median_count, zscore=null() \
| eval finding="MLTK detected index volume ".anomaly_type.": yesterday=".yesterday_count.", baseline_median=".median_count.", pct_change=".pct_change."%" \
| eval likely_cause=case(recovered=1,"MLTK detected an outlier yesterday, but today appears recovered.",recovered=0,"MLTK detected an outlier and today's projection is still abnormal.",true(),"MLTK detected an index-level outlier.") \
| eval recommended_action="Review sourcetype/host/source contributors and correlated _internal/Cribl evidence." \
| eval first_seen=strftime(relative_time(now(),"-1d@d"),"%F %T"), last_seen=strftime(relative_time(now(),"@d"),"%F %T"), updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| eval finding_id=md5(category."|".index."|".anomaly_type."|".first_seen) \
| table finding_id severity category anomaly_type index sourcetype host source finding actual_value baseline_value pct_change zscore ml_score recovered likely_cause recommended_action first_seen last_seen updated_epoch updated yesterday_count \
| outputlookup ddhc_ml_index_anomalies.csv

