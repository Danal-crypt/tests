<form version="1.1" theme="dark">
  <label>Daily Data Health Console</label>
  <description>One-stop daily Splunk ingestion, anomaly, missing data, internal error, data quality, and Cribl pipeline monitoring console. Primary data source: ddhc_findings.csv generated by scheduled searches.</description>

  <fieldset submitButton="true" autoRun="true">
    <input type="time" token="tok_time" searchWhenChanged="false">
      <label>Evidence Time Range</label>
      <default>
        <earliest>-24h</earliest>
        <latest>now</latest>
      </default>
    </input>

    <input type="dropdown" token="tok_severity" searchWhenChanged="false">
      <label>Severity</label>
      <choice value="*">All</choice>
      <choice value="critical">Critical</choice>
      <choice value="high">High</choice>
      <choice value="medium">Medium</choice>
      <choice value="low">Low</choice>
      <choice value="informational">Informational</choice>
      <default>*</default>
    </input>

    <input type="dropdown" token="tok_category" searchWhenChanged="false">
      <label>Category</label>
      <choice value="*">All</choice>
      <choice value="index_volume">Index Volume</choice>
      <choice value="sourcetype_volume">Sourcetype Volume</choice>
      <choice value="ml_index_volume">ML Index Volume</choice>
      <choice value="ml_sourcetype_volume">ML Sourcetype Volume</choice>
      <choice value="ml_license_volume">ML License Volume</choice>
      <choice value="ml_cribl_health">ML Cribl Health</choice>
      <choice value="missing_expected_source">Missing Expected Source</choice>
      <choice value="new_data">New Data</choice>
      <choice value="internal_error">Internal Error</choice>
      <choice value="data_quality">Data Quality</choice>
      <choice value="cribl_health">Cribl Health</choice>
      <default>*</default>
    </input>

    <input type="text" token="tok_index_filter" searchWhenChanged="false">
      <label>Index Filter</label>
      <default>*</default>
    </input>

    <input type="text" token="tok_owner_filter" searchWhenChanged="false">
      <label>Owner Filter</label>
      <default>*</default>
    </input>
  </fieldset>

  <init>
    <set token="tok_drill_index">*</set>
    <set token="tok_drill_sourcetype">*</set>
    <set token="tok_drill_host">*</set>
    <set token="tok_drill_source">*</set>
    <set token="tok_drill_category">*</set>
    <set token="tok_drill_finding_id">*</set>
  </init>

  <row>
    <panel>
      <title>Overall Health</title>
      <single>
        <search>
          <query><![CDATA[
| inputlookup ddhc_findings.csv
| eval status=coalesce(status,"new")
| search status!="resolved" status!="false_positive"
| eval severity_score=case(severity="critical",10,severity="high",6,severity="medium",3,severity="low",1,true(),0)
| stats sum(severity_score) as total_score count as active_findings
| eval health=case(total_score>=50,"RED",total_score>=20,"YELLOW",true(),"GREEN")
| fields health
          ]]></query>
          <earliest>-24h</earliest>
          <latest>now</latest>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x53a051","0xf8be34","0xdc4e41"]</option>
        <option name="rangeValues">[0,1]</option>
        <option name="underLabel">Environment status from active findings</option>
      </single>
    </panel>

    <panel>
      <title>Critical Findings</title>
      <single>
        <search>
          <query><![CDATA[
| inputlookup ddhc_findings.csv
| eval status=coalesce(status,"new")
| search status!="resolved" status!="false_positive" severity="critical"
| stats count
          ]]></query>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
