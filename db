# ============================================================
# Daily Data Health Console - savedsearches.conf
# Purpose:
#   Builds and maintains the lookup files used by the dashboard:
#   Daily Data Health Console.xml
#
# Install location example:
#   $SPLUNK_HOME/etc/apps/<your_monitoring_app>/local/savedsearches.conf
#
# Required manual/optional lookups:
#   ddhc_expected_data_sources.csv
#     Required for expected-source monitoring.
#     Recommended fields:
#       host,index,sourcetype,source,owner,criticality,environment,expected_frequency_minutes,notes
#     Use source="*" when any source is acceptable for the host/index/sourcetype.
#
#   ddhc_finding_status.csv
#     Optional analyst workflow lookup.
#     Recommended fields:
#       finding_id,status,analyst,comment,last_updated
#
#   ddhc_maintenance_windows.csv
#     Optional suppression lookup.
#     Recommended fields:
#       start_epoch,end_epoch,index,sourcetype,host,source,reason,owner
#
# Notes:
#   1. These searches intentionally avoid MLTK and custom commands.
#   2. Adjust indexes searched by replacing index=* with your allowed monitored indexes if needed.
#   3. For large Splunk Cloud environments, run these from a dedicated monitoring app and grant lookup write permissions.
# ============================================================


[DDHC 00 - Build Index Daily Baseline]
disabled = 0
description = Builds same-day-of-week index baselines for yesterday comparisons.
cron_schedule = 10 1 * * *
dispatch.earliest_time = -36d@d
dispatch.latest_time = @d
search = | tstats summariesonly=false count where index=* earliest=-36d@d latest=-1d@d by _time index span=1d \
| eval baseline_dow=strftime(_time,"%A"), target_dow=strftime(relative_time(now(),"-1d@d"),"%A") \
| where baseline_dow=target_dow \
| stats count as baseline_days avg(count) as avg_count median(count) as median_count stdev(count) as stdev_count perc25(count) as p25 perc75(count) as p75 min(count) as min_count max(count) as max_count by index \
| eval updated_epoch=now(), updated=strftime(updated_epoch,"%F %T") \
| outputlookup ddhc_index_daily_baseline.csv


[DDHC 01 - Build Sourcetype Daily Baseline]
disabled = 0
description = Builds same-day-of-week index/sourcetype baselines for yesterday comparisons.
cron_schedule = 20 1 * * *
dispatch.earliest_time = -36d@d
dispatch.latest_time = @d
