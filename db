| makeresults
| eval lookup="ddhc_index_daily_baseline.csv"
| append [ | inputlookup ddhc_index_daily_baseline.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_index_daily_baseline.csv" ]
| append [ | inputlookup ddhc_sourcetype_daily_baseline.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_sourcetype_daily_baseline.csv" ]
| append [ | inputlookup ddhc_host_source_last_seen.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_host_source_last_seen.csv" ]
| append [ | inputlookup ddhc_internal_error_summary.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_internal_error_summary.csv" ]
| append [ | inputlookup ddhc_today_projection.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_today_projection.csv" ]
| append [ | inputlookup ddhc_ml_index_anomalies.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_ml_index_anomalies.csv" ]
| append [ | inputlookup ddhc_ml_sourcetype_anomalies.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_ml_sourcetype_anomalies.csv" ]
| append [ | inputlookup ddhc_ml_license_anomalies.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_ml_license_anomalies.csv" ]
| append [ | inputlookup ddhc_ml_cribl_anomalies.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_ml_cribl_anomalies.csv" ]
| append [ | inputlookup ddhc_findings.csv | stats max(updated_epoch) as updated_epoch | eval lookup="ddhc_findings.csv" ]
| stats max(updated_epoch) as updated_epoch by lookup
| eval updated=strftime(updated_epoch,"%F %T")
| eval age_minutes=round((now()-updated_epoch)/60,1)
| eval status=case(isnull(updated_epoch),"missing_or_empty",age_minutes>180,"stale",true(),"fresh")
| table lookup status updated age_minutes
| sort lookup
          ]]></query>
        </search>
        <option name="count">20</option>
        <format type="color" field="status">
          <colorPalette type="map">{"fresh":"#53a051","stale":"#f8be34","missing_or_empty":"#dc4e41"}</colorPalette>
        </format>
