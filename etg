| rename extracted_host as value
| eval label=value
| dedup value
| sort label
        ]]></query>
        <earliest>$time_tok.earliest$</earliest>
        <latest>$time_tok.latest$</latest>
      </search>
    </input>

    <input type="dropdown" token="data_source_tok">
      <label>Data Source</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>label</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query><![CDATA[
| mstats count WHERE index=criblmetrics AND metric_name="cribl.logstream.source.in_events" BY extracted_source
| where isnotnull(extracted_source)
