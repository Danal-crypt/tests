  </fieldset>

  <row>
    <panel>
      <single>
        <title>Total Bytes In</title>
        <search>
          <query><![CDATA[
| mstats sum(_value) as total WHERE index=criblmetrics AND metric_name="cribl.logstream.total.in_bytes"
| eval Value=case(
    "$byte_unit$"="Bytes", round(total,0),
    "$byte_unit$"="MB", round(total/1024/1024,2),
    "$byte_unit$"="GB", round(total/1024/1024/1024,3)
  )
| fields Value
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
      </single>
    </panel>

    <panel>
      <single>
        <title>Total Bytes Out</title>
        <search>
          <query><![CDATA[
| mstats sum(_value) as total WHERE index=criblmetrics AND metric_name="cribl.logstream.total.out_bytes"
| eval Value=case(
    "$byte_unit$"="Bytes", round(total,0),
    "$byte_unit$"="MB", round(total/1024/1024,2),
    "$byte_unit$"="GB", round(total/1024/1024/1024,3)
  )
| fields Value
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
      </single>
    </panel>

    <panel>
      <single>
        <title>Total Events In</title>
        <search>
          <query><![CDATA[
| mstats sum(_value) as Value WHERE index=criblmetrics AND metric_name="cribl.logstream.total.in_events"
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
      </single>
    </panel>

    <panel>
      <single>
        <title>Total Events Out</title>
        <search>
          <query><![CDATA[
| mstats sum(_value) as Value WHERE index=criblmetrics AND metric_name="cribl.logstream.total.out_events"
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <chart>
        <title>Total Events Over Time</title>
        <search>
          <query><![CDATA[
| mstats sum(_value) as value WHERE index=criblmetrics AND (metric_name="cribl.logstream.total.in_events" OR metric_name="cribl.logstream.total.out_events") span=1m BY metric_name
| eval series=case(
    metric_name="cribl.logstream.total.in_events","Events In",
    metric_name="cribl.logstream.total.out_events","Events Out"
  )
| timechart span=1m sum(value) by series
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
      </chart>
    </panel>

    <panel>
      <chart>
        <title>Total Bytes Over Time</title>
        <search>
          <query><![CDATA[
| mstats sum(_value) as value WHERE index=criblmetrics AND (metric_name="cribl.logstream.total.in_bytes" OR metric_name="cribl.logstream.total.out_bytes") span=1m BY metric_name
| eval series=case(
    metric_name="cribl.logstream.total.in_bytes","Bytes In",
    metric_name="cribl.logstream.total.out_bytes","Bytes Out"
  )
| eval value=case(
    "$byte_unit$"="Bytes", value,
    "$byte_unit$"="MB", value/1024/1024,
    "$byte_unit$"="GB", value/1024/1024/1024
  )
| timechart span=1m sum(value) by series
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <table>
        <title>Cribl Sources (documented input-side totals)</title>
        <search>
          <query><![CDATA[
| mstats sum(_value) as value WHERE index=criblmetrics AND (metric_name="cribl.logstream.total.in_bytes" OR metric_name="cribl.logstream.total.in_events") BY metric_name input
| where "$cribl_source_tok$"="*" OR input="$cribl_source_tok$"
| eval bytes_in=if(metric_name="cribl.logstream.total.in_bytes", value, 0)
| eval events_in=if(metric_name="cribl.logstream.total.in_events", value, 0)
| stats sum(bytes_in) as bytes_in sum(events_in) as events_in by input
| sort 0 - bytes_in - events_in
| eval "Bytes In ($byte_unit$)"=case(
    "$byte_unit$"="Bytes", round(bytes_in,0),
    "$byte_unit$"="MB", round(bytes_in/1024/1024,2),
    "$byte_unit$"="GB", round(bytes_in/1024/1024/1024,3)
  )
| rename input as "Cribl Source" events_in as "Events In"
| table "Cribl Source" "Bytes In ($byte_unit$)" "Events In"
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">20</option>
      </table>
    </panel>

    <panel>
      <table>
        <title>Cribl Destinations (documented output-side totals)</title>
        <search>
          <query><![CDATA[
| mstats sum(_value) as value WHERE index=criblmetrics AND (metric_name="cribl.logstream.total.out_bytes" OR metric_name="cribl.logstream.total.out_events" OR metric_name="cribl.logstream.total.dropped_events") BY metric_name output
| where "$dest_tok$"="*" OR output="$dest_tok$"
| eval bytes_out=if(metric_name="cribl.logstream.total.out_bytes", value, 0)
| eval events_out=if(metric_name="cribl.logstream.total.out_events", value, 0)
| eval dropped_events=if(metric_name="cribl.logstream.total.dropped_events", value, 0)
| stats sum(bytes_out) as bytes_out sum(events_out) as events_out sum(dropped_events) as dropped_events by output
| sort 0 - bytes_out - events_out - dropped_events
| eval "Bytes Out ($byte_unit$)"=case(
    "$byte_unit$"="Bytes", round(bytes_out,0),
    "$byte_unit$"="MB", round(bytes_out/1024/1024,2),
    "$byte_unit$"="GB", round(bytes_out/1024/1024/1024,3)
  )
| rename output as "Cribl Destination" events_out as "Events Out" dropped_events as "Dropped Events"
| table "Cribl Destination" "Bytes Out ($byte_unit$)" "Events Out" "Dropped Events"
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">20</option>
      </table>
    </panel>
  </row>

  <row>
