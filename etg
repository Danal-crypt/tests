<form version="1.1" theme="light">
  <label>Cribl Metrics - Stream 4.17</label>
  <description>Fixed dashboard for index=criblmetrics using documented Cribl Stream metric families.</description>

  <fieldset submitButton="false">
    <input type="time" token="time_tok">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>

    <input type="dropdown" token="byte_unit">
      <label>Byte Display Unit</label>
      <choice value="Bytes">Bytes</choice>
      <choice value="MB">Megabytes</choice>
      <choice value="GB">Gigabytes</choice>
      <default>MB</default>
    </input>

    <input type="dropdown" token="cribl_source_tok">
      <label>Cribl Source</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>label</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query><![CDATA[
| mstats count WHERE index=criblmetrics AND metric_name="cribl.logstream.total.in_events" BY input
| fields input
| where isnotnull(input)
| rename input as value
| eval label=value
| dedup value
| sort label
        ]]></query>
        <earliest>$time_tok.earliest$</earliest>
        <latest>$time_tok.latest$</latest>
      </search>
    </input>

    <input type="dropdown" token="dest_tok">
      <label>Cribl Destination</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>label</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query><![CDATA[
| mstats count WHERE index=criblmetrics AND metric_name="cribl.logstream.total.out_events" BY output
| fields output
| where isnotnull(output)
| rename output as value
| eval label=value
| dedup value
| sort label
        ]]></query>
        <earliest>$time_tok.earliest$</earliest>
        <latest>$time_tok.latest$</latest>
      </search>
    </input>

    <input type="dropdown" token="route_tok">
      <label>Route</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>label</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query><![CDATA[
| mstats count WHERE index=criblmetrics AND metric_name="cribl.logstream.route.in_events" BY route
| fields route
| where isnotnull(route)
| rename route as value
| eval label=value
| dedup value
| sort label
        ]]></query>
        <earliest>$time_tok.earliest$</earliest>
        <latest>$time_tok.latest$</latest>
      </search>
    </input>

    <input type="dropdown" token="pipeline_tok">
      <label>Pipeline</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>label</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query><![CDATA[
| mstats count WHERE index=criblmetrics AND metric_name="cribl.logstream.pipe.in_events" BY pipeline pipe
| eval pipeline_name=coalesce(pipeline, pipe)
| where isnotnull(pipeline_name)
| fields pipeline_name
| rename pipeline_name as value
| eval label=value
| dedup value
| sort label
        ]]></query>
        <earliest>$time_tok.earliest$</earliest>
        <latest>$time_tok.latest$</latest>
      </search>
    </input>

    <input type="dropdown" token="data_index_tok">
      <label>Data Index</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>label</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query><![CDATA[
| mstats count WHERE index=criblmetrics AND metric_name="cribl.logstream.index.in_events" BY extracted_index
| where isnotnull(extracted_index)
| fields extracted_index
| rename extracted_index as value
| eval label=value
| dedup value
| sort label
        ]]></query>
        <earliest>$time_tok.earliest$</earliest>
        <latest>$time_tok.latest$</latest>
      </search>
    </input>

    <input type="dropdown" token="data_sourcetype_tok">
      <label>Data Sourcetype</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>label</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
        <query><![CDATA[
| mstats count WHERE index=criblmetrics AND metric_name="cribl.logstream.sourcetype.in_events" BY extracted_sourcetype
| where isnotnull(extracted_sourcetype)
| fields extracted_sourcetype
| rename extracted_sourcetype as value
| eval label=value
| dedup value
| sort label
        ]]></query>
        <earliest>$time_tok.earliest$</earliest>
        <latest>$time_tok.latest$</latest>
      </search>
    </input>

    <input type="dropdown" token="data_host_tok">
      <label>Data Host</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>label</fieldForLabel>
      <fieldForValue>value</fieldForValue>
      <search>
