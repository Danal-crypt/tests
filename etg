| stats sum(events_in) as events_in sum(events_out) as events_out sum(dropped_events) as dropped_events by pipeline_name
| sort 0 - events_out - dropped_events - events_in
| rename pipeline_name as Pipeline events_in as "Events In" events_out as "Events Out" dropped_events as "Dropped Events"
| table Pipeline "Events In" "Events Out" "Dropped Events"
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">20</option>
      </table>
    </panel>
  </row>

