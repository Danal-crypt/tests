| where "$route_tok$"="*" OR route="$route_tok$"
| eval bytes_in=if(metric_name="cribl.logstream.route.in_bytes", value, 0)
| eval bytes_out=if(metric_name="cribl.logstream.route.out_bytes", value, 0)
| eval events_in=if(metric_name="cribl.logstream.route.in_events", value, 0)
| eval events_out=if(metric_name="cribl.logstream.route.out_events", value, 0)
| eval dropped_events=if(metric_name="cribl.logstream.route.dropped_events", value, 0)
| stats sum(bytes_in) as bytes_in sum(bytes_out) as bytes_out sum(events_in) as events_in sum(events_out) as events_out sum(dropped_events) as dropped_events by route
| sort 0 - bytes_out - events_out - bytes_in - events_in
| eval "Bytes In ($byte_unit$)"=case(
    "$byte_unit$"="Bytes", round(bytes_in,0),
    "$byte_unit$"="MB", round(bytes_in/1024/1024,2),
    "$byte_unit$"="GB", round(bytes_in/1024/1024/1024,3)
  )
| eval "Bytes Out ($byte_unit$)"=case(
    "$byte_unit$"="Bytes", round(bytes_out,0),
    "$byte_unit$"="MB", round(bytes_out/1024/1024,2),
    "$byte_unit$"="GB", round(bytes_out/1024/1024/1024,3)
  )
| rename route as Route events_in as "Events In" events_out as "Events Out" dropped_events as "Dropped Events"
| table Route "Bytes In ($byte_unit$)" "Bytes Out ($byte_unit$)" "Events In" "Events Out" "Dropped Events"
          ]]></query>
          <earliest>$time_tok.earliest$</earliest>
          <latest>$time_tok.latest$</latest>
        </search>
        <option name="count">20</option>
      </table>
    </panel>

    <panel>
